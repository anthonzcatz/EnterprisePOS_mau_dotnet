<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.ErrorView"
             x:Name="Root">
    <VerticalStackLayout VerticalOptions="Center" 
                        HorizontalOptions="Center"
                        Spacing="12"
                        Padding="40">
        <Label Text="⚠️"
               FontSize="48"
               HorizontalOptions="Center" />
        
        <Label Text="{Binding Title, Source={x:Reference Root}}"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="{StaticResource Error}"
               HorizontalOptions="Center" />
        
        <Label Text="{Binding Message, Source={x:Reference Root}}"
               TextColor="{StaticResource Gray500}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
        
        <Button Text="Retry"
                Command="{Binding RetryCommand, Source={x:Reference Root}}"
                IsVisible="{Binding HasRetry, Source={x:Reference Root}}"
                HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentView>
