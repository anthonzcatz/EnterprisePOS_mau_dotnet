<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PosSidebarView"
             x:Name="Root"
             BackgroundColor="{StaticResource White}">
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="{Binding Source={x:Reference Root}, Path=SidebarPadding}">

        <!-- Brand -->
        <Grid Grid.Row="0"
              HeightRequest="52"
              Margin="0,0,0,20"
              HorizontalOptions="Fill">
            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="{Binding Source={x:Reference Root}, Path=HeaderHorizontalOptions}"
                                   VerticalOptions="Center">
                <Border WidthRequest="48"
                        HeightRequest="48"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Image Source="logo.png"
                           WidthRequest="36"
                           HeightRequest="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Aspect="AspectFill" />
                </Border>
                <VerticalStackLayout Spacing="0"
                                     VerticalOptions="Center"
                                     IsVisible="{Binding Source={x:Reference Root}, Path=ShowLabels}">
                    <Label Text="TechFuxion POS"
                           TextColor="{StaticResource Gray900}"
                           FontAttributes="Bold"
                           FontSize="14"
                           LineBreakMode="TailTruncation" />
                    <Label Text="Enterprise System"
                           TextColor="{StaticResource Gray500}"
                           FontSize="10" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>

        <!-- Nav (ScrollView avoids CollectionView left inset on WinUI) -->
        <ScrollView Grid.Row="1"
                    Orientation="Vertical"
                    VerticalScrollBarVisibility="Never"
                    HorizontalOptions="Fill">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference Root}, Path=NavItems}"
                                 Spacing="4"
                                 HorizontalOptions="Fill"
                                 Padding="{Binding Source={x:Reference Root}, Path=NavListPadding}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid HorizontalOptions="Fill"
                              HeightRequest="48">
                            <!-- Collapsed: icon centered in sidebar -->
                            <Border IsVisible="{Binding Source={x:Reference Root}, Path=IsCollapsed}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource ButtonPrimary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=NavigateCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border WidthRequest="36"
                                        HeightRequest="36"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource ButtonPrimary}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Glyph}"
                                           FontSize="17"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="#1F2A3D">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="TextColor" Value="#FFFFFF" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Border>

                            <!-- Expanded: symmetric row -->
                            <Border IsVisible="{Binding Source={x:Reference Root}, Path=ShowLabels}"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    Padding="10,6"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource ButtonPrimary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=NavigateCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="40,*"
                                      ColumnSpacing="10"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            StrokeThickness="0"
                                            BackgroundColor="Transparent"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource ButtonPrimary}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding Glyph}"
                                               FontSize="17"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="#1F2A3D">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="TextColor" Value="#FFFFFF" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           TextColor="#1F2A3D">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="TextColor" Value="#FFFFFF" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Toggle -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="{StaticResource ButtonPrimary}"
                WidthRequest="44"
                HeightRequest="44"
                Margin="0,12,0,0"
                HorizontalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=ToggleCommand}" />
            </Border.GestureRecognizers>
            <Label Text="{Binding Source={x:Reference Root}, Path=ToggleIcon}"
                   FontSize="17"
                   TextColor="{StaticResource ButtonPrimaryText}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentView>


