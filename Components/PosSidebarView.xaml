<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PosSidebarView"
             x:Name="Root"
             BackgroundColor="{StaticResource PosSidebar}">
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="{Binding Source={x:Reference Root}, Path=SidebarPadding}">

        <!-- Brand -->
        <Grid Grid.Row="0"
              HeightRequest="52"
              Margin="0,0,0,20"
              HorizontalOptions="Fill">
            <HorizontalStackLayout Spacing="10"
                                   HorizontalOptions="{Binding Source={x:Reference Root}, Path=HeaderHorizontalOptions}"
                                   VerticalOptions="Center">
                <Border BackgroundColor="{StaticResource PosSidebarAccent}"
                        WidthRequest="40"
                        HeightRequest="40"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label Text="☕"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#0F1114"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Spacing="0"
                                     VerticalOptions="Center"
                                     IsVisible="{Binding Source={x:Reference Root}, Path=ShowLabels}">
                    <Label Text="Dos Avenue"
                           TextColor="{StaticResource White}"
                           FontAttributes="Bold"
                           FontSize="14"
                           LineBreakMode="TailTruncation" />
                    <Label Text="Coffee &amp; Bites"
                           TextColor="{StaticResource Gray400}"
                           FontSize="10" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>

        <!-- Nav (ScrollView avoids CollectionView left inset on WinUI) -->
        <ScrollView Grid.Row="1"
                    Orientation="Vertical"
                    VerticalScrollBarVisibility="Never"
                    HorizontalOptions="Fill">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Source={x:Reference Root}, Path=NavItems}"
                                 Spacing="4"
                                 HorizontalOptions="Fill"
                                 Padding="{Binding Source={x:Reference Root}, Path=NavListPadding}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid HorizontalOptions="Fill"
                              HeightRequest="48">
                            <!-- Collapsed: icon centered in sidebar -->
                            <Border IsVisible="{Binding Source={x:Reference Root}, Path=IsCollapsed}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource PosNavActive}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=NavigateCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border WidthRequest="36"
                                        HeightRequest="36"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Glyph}"
                                           FontSize="17"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="{StaticResource Gray400}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource OffBlack}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Border>

                            <!-- Expanded: symmetric row -->
                            <Border IsVisible="{Binding Source={x:Reference Root}, Path=ShowLabels}"
                                    StrokeThickness="0"
                                    BackgroundColor="Transparent"
                                    Padding="10,6"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource PosNavActive}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=NavigateCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="40,*"
                                      ColumnSpacing="10"
                                      HorizontalOptions="Fill"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            StrokeThickness="0"
                                            BackgroundColor="Transparent"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding Glyph}"
                                               FontSize="17"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource Gray400}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource OffBlack}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           TextColor="{StaticResource Gray400}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource White}" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Toggle -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="{StaticResource PosNavActive}"
                Padding="10,10"
                Margin="0,12,0,0"
                HorizontalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=ToggleCommand}" />
            </Border.GestureRecognizers>
            <Label Text="{Binding Source={x:Reference Root}, Path=ToggleIcon}"
                   FontSize="18"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentView>


