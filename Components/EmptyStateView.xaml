<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.EmptyStateView"
             x:Name="Root">
    <VerticalStackLayout VerticalOptions="Center" 
                        HorizontalOptions="Center"
                        Spacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}"
                        Padding="{OnIdiom Phone=24, Tablet=32, Desktop=40}">
        <Label Text="{Binding Icon, Source={x:Reference Root}}"
               FontSize="{OnIdiom Phone=48, Tablet=64, Desktop=80}"
               HorizontalOptions="Center" />
        
        <Label Text="{Binding Title, Source={x:Reference Root}}"
               FontSize="{OnIdiom Phone=16, Tablet=18, Desktop=20}"
               FontAttributes="Bold"
               TextColor="{StaticResource Gray900}"
               HorizontalOptions="Center" />
        
        <Label Text="{Binding Message, Source={x:Reference Root}}"
               TextColor="{StaticResource Gray500}"
               FontSize="{OnIdiom Phone=13, Tablet=14, Desktop=15}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
        
        <Button Text="{Binding ActionText, Source={x:Reference Root}}"
                Command="{Binding ActionCommand, Source={x:Reference Root}}"
                IsVisible="{Binding HasAction, Source={x:Reference Root}}"
                HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentView>
