<?xml version="1.0" encoding="utf-8" ?>
<!--
  Product card matching the reference screenshot:
  - Rounded card with light gray image area
  - Dark pill stock badge top-left over the image
  - Bold product name, muted description (2 lines max)
  - Price in dark/black
  - Small "Add to Cart" outline pill button at bottom
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PosProductCardView"
             x:Name="Root">
    <Border BackgroundColor="{StaticResource PosCard}"
            Stroke="{StaticResource PosBorder}"
            StrokeThickness="1"
            Padding="{OnIdiom Phone=10, Tablet=12, Desktop=16}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16" />
        </Border.StrokeShape>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
                            <Setter Property="BackgroundColor" Value="#F9FAFB" />
                            <Setter Property="TranslationY" Value="-1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </VisualStateManager.VisualStateGroups>
        <VerticalStackLayout Spacing="{OnIdiom Phone=8, Tablet=10, Desktop=12}">

            <!-- ── Image + stock badge ── -->
            <Grid HeightRequest="{OnIdiom Phone=110, Tablet=125, Desktop=140}">
                <!-- Rounded image area -->
                <Border StrokeThickness="0"
                        BackgroundColor="{StaticResource Gray100}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Image Source="{Binding Source={x:Reference Root}, Path=ImageSource}"
                           Aspect="AspectFill" />
                </Border>

                <!-- Stock badge — dark pill top-left -->
                <Border BackgroundColor="{StaticResource PosStockBadge}"
                        StrokeThickness="0"
                        Padding="{OnIdiom Phone='6,3', Tablet='8,4', Desktop='10,5'}"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="{OnIdiom Phone='6,6,0,0', Tablet='8,8,0,0', Desktop='10,10,0,0'}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Source={x:Reference Root}, Path=StockBadgeText}"
                           TextColor="{StaticResource White}"
                           FontSize="{OnIdiom Phone=9, Tablet=10, Desktop=11}"
                           FontAttributes="Bold" />
                </Border>
            </Grid>

            <!-- ── Name ── -->
            <Label Text="{Binding Source={x:Reference Root}, Path=Title}"
                   FontAttributes="Bold"
                   FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}"
                   TextColor="{StaticResource Gray900}"
                   LineBreakMode="TailTruncation"
                   MaxLines="1" />

            <!-- ── Description ── -->
            <Label Text="{Binding Source={x:Reference Root}, Path=Description}"
                   FontSize="{OnIdiom Phone=10, Tablet=11, Desktop=12}"
                   TextColor="{StaticResource PosTextMuted}"
                   MaxLines="2"
                   LineBreakMode="TailTruncation" />

            <!-- ── Price ── -->
            <Label Text="{Binding Source={x:Reference Root}, Path=PriceText}"
                   FontAttributes="Bold"
                   FontSize="{OnIdiom Phone=13, Tablet=14, Desktop=15}"
                   TextColor="{StaticResource Gray900}" />

            <!-- ── Add to Cart — Border+Tap works reliably on WinUI MSIX ── -->
            <Border Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1.5"
                    BackgroundColor="Transparent"
                    Padding="{OnIdiom Phone='8,5', Tablet='10,6', Desktop='12,8'}"
                    HorizontalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=AddCommand}"
                                        CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                </Border.GestureRecognizers>
                <Label Text="+ Add to Cart"
                       FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gray900}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </Border>
        </VerticalStackLayout>
    </Border>
</ContentView>
