<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.MetricCardView"
             x:Name="This">
    <Border Padding="16"
            BackgroundColor="{StaticResource White}"
            Stroke="{StaticResource PosBorder}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 18">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="12">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <Label Grid.Column="0"
                       Text="{Binding Source={x:Reference This}, Path=Title}"
                       FontSize="12"
                       TextColor="{StaticResource Gray500}" />
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Gray100}"
                        StrokeThickness="0"
                        Padding="8,4"
                        MinimumWidthRequest="34">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Source={x:Reference This}, Path=Icon}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Gray900}" />
                </Border>
            </Grid>

            <Label Grid.Row="1"
                   Text="{Binding Source={x:Reference This}, Path=Value}"
                   FontAttributes="Bold"
                   FontSize="24"
                   TextColor="{StaticResource Gray900}" />

            <Label Grid.Row="2"
                   Text="{Binding Source={x:Reference This}, Path=Delta}"
                   FontSize="12">
                <Label.Triggers>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding Source={x:Reference This}, Path=IsPositive}"
                                 Value="True">
                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding Source={x:Reference This}, Path=IsPositive}"
                                 Value="False">
                        <Setter Property="TextColor" Value="{StaticResource Danger}" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
        </Grid>
    </Border>
</ContentView>
