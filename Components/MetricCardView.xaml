<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.MetricCardView"
             x:Name="This">
    <Border Padding="{OnIdiom Phone=12, Tablet=16, Desktop=20}"
            BackgroundColor="{StaticResource White}"
            Stroke="{StaticResource PosBorder}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 16">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Source={x:Reference This}, Path=Command}"
                                CommandParameter="{Binding Source={x:Reference This}, Path=CommandParameter}"/>
        </Border.GestureRecognizers>
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="{OnIdiom Phone=8, Tablet=10, Desktop=12}">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="{OnIdiom Phone=6, Tablet=8, Desktop=10}">
                <Label Grid.Column="0"
                       Text="{Binding Source={x:Reference This}, Path=Title}"
                       FontSize="{OnIdiom Phone=10, Tablet=12, Desktop=14}"
                       TextColor="{StaticResource Gray500}" />
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Gray100}"
                        StrokeThickness="0"
                        Padding="8,4"
                        MinimumWidthRequest="34">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Label Text="{Binding Source={x:Reference This}, Path=Icon}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Gray900}" />
                </Border>
            </Grid>

            <Label Grid.Row="1"
                   Text="{Binding Source={x:Reference This}, Path=Value}"
                   FontAttributes="Bold"
                   FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=28}"
                   TextColor="{StaticResource Gray900}" />

            <Label Grid.Row="2"
                   Text="{Binding Source={x:Reference This}, Path=Delta}"
                   FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}">
                <Label.Triggers>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding Source={x:Reference This}, Path=IsPositive}"
                                 Value="True">
                        <Setter Property="TextColor" Value="{StaticResource Success}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label"
                                 Binding="{Binding Source={x:Reference This}, Path=IsPositive}"
                                 Value="False">
                        <Setter Property="TextColor" Value="{StaticResource Danger}" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
        </Grid>
    </Border>
</ContentView>
