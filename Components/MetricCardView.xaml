<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.MetricCardView"
             x:Name="This">
    <Border Padding="16"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
            StrokeShape="RoundRectangle 14">
        <VerticalStackLayout Spacing="6">
            <Label Text="{Binding Source={x:Reference This}, Path=Title}"
                   FontSize="12"
                   TextColor="{StaticResource Gray500}" />
            <Label Text="{Binding Source={x:Reference This}, Path=Value}"
                   FontAttributes="Bold"
                   FontSize="20" />
            <Label Text="{Binding Source={x:Reference This}, Path=Delta}"
                   FontSize="12"
                   TextColor="{StaticResource Primary}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
