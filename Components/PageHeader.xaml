<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PageHeader"
             x:Name="Root">
    <VerticalStackLayout Spacing="4">
        <Label Text="{Binding Title, Source={x:Reference Root}}"
               Style="{StaticResource Headline}"
               HorizontalOptions="Start"
               HorizontalTextAlignment="Start" />
        
        <Label Text="{Binding Description, Source={x:Reference Root}}"
               TextColor="{StaticResource Gray500}"
               IsVisible="{Binding HasDescription, Source={x:Reference Root}}" />
    </VerticalStackLayout>
</ContentView>
