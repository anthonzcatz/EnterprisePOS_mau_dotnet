<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PosCartLineView"
             x:Name="Root">
    <Border BackgroundColor="{StaticResource Gray100}"
            Stroke="{StaticResource PosBorder}"
            StrokeThickness="1"
            Padding="10"
            StrokeShape="RoundRectangle 12"
            Margin="0,0,0,8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="10"
              RowSpacing="6">
            <Border Grid.RowSpan="2"
                    Grid.Column="0"
                    WidthRequest="48"
                    HeightRequest="48"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource White}"
                    VerticalOptions="Start">
                <Image Source="{Binding Source={x:Reference Root}, Path=ImageSource}"
                       Aspect="AspectFill"
                       Margin="4" />
            </Border>

            <VerticalStackLayout Grid.Row="0"
                                 Grid.Column="1"
                                 Spacing="4">
                <Label Text="{Binding Source={x:Reference Root}, Path=Title}"
                       FontAttributes="Bold"
                       FontSize="13"
                       TextColor="{StaticResource Gray900}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
                <Label Text="{Binding Source={x:Reference Root}, Path=Description}"
                       FontSize="12"
                       TextColor="{StaticResource PosTextMuted}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
            </VerticalStackLayout>

            <!-- Delete — fixed 20x20 (WinUI ignores small Button sizes) -->
            <Border Grid.Row="0"
                    Grid.Column="2"
                    WidthRequest="20"
                    HeightRequest="20"
                    MinimumWidthRequest="20"
                    MaximumWidthRequest="20"
                    MinimumHeightRequest="20"
                    MaximumHeightRequest="20"
                    BackgroundColor="#DC2626"
                    StrokeThickness="0"
                    VerticalOptions="Start"
                    HorizontalOptions="End">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=DeleteCommand}"
                                          CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                </Border.GestureRecognizers>
                <Label Text="🗑"
                       FontSize="9"
                       TextColor="{StaticResource White}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>

            <HorizontalStackLayout Grid.Row="1"
                                   Grid.Column="1"
                                   Spacing="6"
                                   VerticalOptions="Center">
                <Border WidthRequest="22"
                        HeightRequest="22"
                        MinimumWidthRequest="22"
                        MaximumWidthRequest="22"
                        MinimumHeightRequest="22"
                        MaximumHeightRequest="22"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="11" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=DecreaseCommand}"
                                              CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                    </Border.GestureRecognizers>
                    <Label Text="−"
                           FontSize="12"
                           TextColor="{StaticResource Gray900}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
                <Label Text="{Binding Source={x:Reference Root}, Path=QuantityText, StringFormat='{0:D2}'}"
                       VerticalOptions="Center"
                       WidthRequest="20"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"
                       FontSize="11"
                       TextColor="{StaticResource Gray900}" />
                <Border WidthRequest="22"
                        HeightRequest="22"
                        MinimumWidthRequest="22"
                        MaximumWidthRequest="22"
                        MinimumHeightRequest="22"
                        MaximumHeightRequest="22"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="11" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=IncreaseCommand}"
                                              CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                    </Border.GestureRecognizers>
                    <Label Text="+"
                           FontSize="12"
                           TextColor="{StaticResource OffBlack}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </HorizontalStackLayout>

            <Label Grid.Row="1"
                   Grid.Column="2"
                   Text="{Binding Source={x:Reference Root}, Path=TotalText}"
                   VerticalOptions="Center"
                   HorizontalOptions="End"
                   FontSize="11"
                   TextColor="{StaticResource Gray500}" />
        </Grid>
    </Border>
</ContentView>
