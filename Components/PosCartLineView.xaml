<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Components.PosCartLineView"
             x:Name="Root">
    <Border BackgroundColor="{StaticResource Gray100}"
            Stroke="{StaticResource PosBorder}"
            StrokeThickness="1"
            Padding="10"
            StrokeShape="RoundRectangle 12"
            Margin="0,0,0,6">
        <Grid ColumnDefinitions="Auto,*,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="10"
              RowSpacing="3">
            <Border Grid.RowSpan="2"
                    Grid.Column="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource White}"
                    VerticalOptions="Center">
                <Image Source="{Binding Source={x:Reference Root}, Path=ImageSource}"
                       Aspect="AspectFill" />
            </Border>

            <VerticalStackLayout Grid.Row="0"
                                 Grid.Column="1"
                                 Spacing="1">
                <Label Text="{Binding Source={x:Reference Root}, Path=Title}"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="{StaticResource Gray900}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
                <Label Text="{Binding Source={x:Reference Root}, Path=Description}"
                       FontSize="10"
                       TextColor="{StaticResource PosTextMuted}"
                       LineBreakMode="TailTruncation"
                       MaxLines="1" />
            </VerticalStackLayout>

            <!-- Delete -->
            <Border Grid.Row="0"
                    Grid.Column="2"
                    WidthRequest="22"
                    HeightRequest="22"
                    MinimumWidthRequest="22"
                    MaximumWidthRequest="22"
                    MinimumHeightRequest="22"
                    MaximumHeightRequest="22"
                    BackgroundColor="{StaticResource PosDangerRed}"
                    StrokeThickness="0"
                    VerticalOptions="Start"
                    HorizontalOptions="End"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="11" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=DeleteCommand}"
                                          CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                </Border.GestureRecognizers>
                <Label Text="🗑"
                       FontSize="10"
                       TextColor="{StaticResource White}"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       Padding="0,-2,0,0" />
            </Border>

            <!-- Row 1: Qty controls + Total -->
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="8"
                  VerticalOptions="Center">
                <!-- Qty controls -->
                <HorizontalStackLayout Grid.Column="0"
                                       Spacing="5"
                                       VerticalOptions="Center">
                    <Border WidthRequest="20"
                            HeightRequest="20"
                            MinimumWidthRequest="20"
                            MaximumWidthRequest="20"
                            MinimumHeightRequest="20"
                            MaximumHeightRequest="20"
                            BackgroundColor="{StaticResource White}"
                            Stroke="{StaticResource PosBorder}"
                            StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=DecreaseCommand}"
                                                  CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                        </Border.GestureRecognizers>
                        <Label Text="-"
                               FontSize="10"
                               TextColor="{StaticResource Gray900}"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               Padding="0,-2,0,0" />
                    </Border>
                    <Label Text="{Binding Source={x:Reference Root}, Path=QuantityText, StringFormat='{0:D2}'}"
                           VerticalOptions="Center"
                           WidthRequest="20"
                           HorizontalTextAlignment="Center"
                           FontAttributes="Bold"
                           FontSize="11"
                           TextColor="{StaticResource Gray900}" />
                    <Border WidthRequest="20"
                            HeightRequest="20"
                            MinimumWidthRequest="20"
                            MaximumWidthRequest="20"
                            MinimumHeightRequest="20"
                            MaximumHeightRequest="20"
                            BackgroundColor="{StaticResource Success}"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=IncreaseCommand}"
                                                  CommandParameter="{Binding Source={x:Reference Root}, Path=CommandParameter}" />
                        </Border.GestureRecognizers>
                        <Label Text="+"
                               FontSize="10"
                               TextColor="{StaticResource White}"
                               HorizontalOptions="Fill"
                               VerticalOptions="Fill"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               Padding="0,-3,0,0" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Line Total -->
                <Label Grid.Column="1"
                       Text="{Binding Source={x:Reference Root}, Path=TotalText}"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       FontSize="11"
                       TextColor="{StaticResource Gray500}" />
            </Grid>
        </Grid>
    </Border>
</ContentView>
