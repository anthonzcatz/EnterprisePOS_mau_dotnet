<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== PRIMARY COLORS (Professional Enterprise Palette) ===== -->
    <Color x:Key="Primary">#356AE6</Color>
    <Color x:Key="PrimaryDark">#2F63B8</Color>
    <Color x:Key="PrimaryLight">#EAF1FF</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>

    <!-- ===== BUTTON COLORS (Template for Primary/CTA Actions) ===== -->
    <Color x:Key="ButtonPrimary">#C2F970</Color>
    <Color x:Key="ButtonPrimaryText">#1F2A3D</Color>
    <Color x:Key="ButtonSecondary">#356AE6</Color>
    <Color x:Key="ButtonSecondaryText">#FFFFFF</Color>

    <!-- ===== NAVIGATION COLORS (Template-based for all nav elements) ===== -->
    <Color x:Key="NavActive">#356AE6</Color>
    <Color x:Key="NavBackground">#FFFFFF</Color>
    <Color x:Key="NavText">#1F2A3D</Color>
    <Color x:Key="NavTextMuted">#73819A</Color>

    <!-- ===== SEMANTIC COLORS ===== -->
    <Color x:Key="Success">#1FA66A</Color>
    <Color x:Key="SuccessLight">#E6F6EF</Color>
    <Color x:Key="Warning">#C88A24</Color>
    <Color x:Key="WarningLight">#FFF4E2</Color>
    <Color x:Key="Danger">#D95364</Color>
    <Color x:Key="DangerLight">#FCECEF</Color>
    <Color x:Key="Info">#6E56CF</Color>
    <Color x:Key="InfoLight">#F1EBFF</Color>

    <!-- ===== NEUTRAL COLORS ===== -->
    <Color x:Key="BackgroundPrimary">#FFFFFF</Color>
    <Color x:Key="BackgroundSecondary">#F4F7FC</Color>
    <Color x:Key="BackgroundTertiary">#EEF3FB</Color>
    <Color x:Key="TextPrimary">#1F2A3D</Color>
    <Color x:Key="TextSecondary">#4B5B74</Color>
    <Color x:Key="TextMuted">#73819A</Color>
    <Color x:Key="BorderColor">#D7E1F0</Color>

    <!-- ===== SIDEBAR / HEADER COLORS ===== -->
    <Color x:Key="SidebarBackgroundStart">#1F3353</Color>
    <Color x:Key="SidebarBackgroundEnd">#2F63B8</Color>
    <Color x:Key="SidebarActiveItem">#356AE6</Color>
    <Color x:Key="SidebarHoverItem">#2A456C</Color>
    <Color x:Key="SidebarText">#FFFFFF</Color>
    <Color x:Key="SidebarTextMuted">#C9D5E7</Color>

    <!-- ===== CHART ACCENT COLORS ===== -->
    <Color x:Key="ChartBlue">#356AE6</Color>
    <Color x:Key="ChartGreen">#1FA66A</Color>
    <Color x:Key="ChartYellow">#C88A24</Color>
    <Color x:Key="ChartRed">#D95364</Color>
    <Color x:Key="ChartPurple">#6E56CF</Color>
    <Color x:Key="ChartTeal">#3A7BD5</Color>

    <!-- ===== GRADIENTS ===== -->
    <Color x:Key="ChartGradientStart">#2F63B8</Color>
    <Color x:Key="ChartGradientEnd">#3A7BD5</Color>

    <!-- ===== BASE COLORS ===== -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#121820</Color>
    <Color x:Key="Magenta">#356AE6</Color>
    <Color x:Key="MidnightBlue">#1F3353</Color>

    <!-- ===== LEGACY COMPAT (referenced by default Styles.xaml) ===== -->
    <Color x:Key="Secondary">#6E56CF</Color>
    <Color x:Key="SecondaryDark">#5A44B8</Color>
    <Color x:Key="SecondaryDarkText">#FFFFFF</Color>
    <Color x:Key="SecondaryLight">#F1EBFF</Color>

    <!-- ===== GRAY SCALE ===== -->
    <Color x:Key="Gray50">#F8FAFD</Color>
    <Color x:Key="Gray100">#EEF3FB</Color>
    <Color x:Key="Gray200">#D7E1F0</Color>
    <Color x:Key="Gray300">#C5D2E5</Color>
    <Color x:Key="Gray400">#A5B4C8</Color>
    <Color x:Key="Gray500">#73819A</Color>
    <Color x:Key="Gray600">#5F6E86</Color>
    <Color x:Key="Gray700">#4B5B74</Color>
    <Color x:Key="Gray800">#2F3D52</Color>
    <Color x:Key="Gray900">#1F2A3D</Color>
    <Color x:Key="Gray950">#121820</Color>

    <!-- ===== POS LAYOUT TOKENS (backward compat) ===== -->
    <Color x:Key="PosSidebar">#1F3353</Color>
    <Color x:Key="PosNavActive">#356AE6</Color>
    <Color x:Key="PosCanvas">#F4F7FC</Color>
    <Color x:Key="PosCard">#FFFFFF</Color>
    <Color x:Key="PosBorder">#D7E1F0</Color>
    <Color x:Key="PosTextMuted">#73819A</Color>
    <Color x:Key="PosStockBadge">#1F3353</Color>

    <!-- ===== CARD COLORS ===== -->
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <!-- ===== POS-SPECIFIC COLORS ===== -->
    <Color x:Key="PosAccentGreen">#1FA66A</Color>
    <Color x:Key="PosDangerRed">#D95364</Color>
    <Color x:Key="PosOverlayDark">#66000000</Color>
    <Color x:Key="PosOverlayMedium">#80000000</Color>
    <Color x:Key="PosSidebarAccent">#6AA5FF</Color>
    <Color x:Key="PosCartBackground">#F2F6FD</Color>
    <Color x:Key="PosDarkGray">#202C3C</Color>

    <!-- ===== CHART LEGEND COLORS ===== -->
    <Color x:Key="ChartLegend1">#356AE6</Color>
    <Color x:Key="ChartLegend2">#6E56CF</Color>
    <Color x:Key="ChartLegend3">#1FA66A</Color>

    <!-- ===== BRUSHES ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLight}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLight}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLight}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLight}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimary}" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondary}" />
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="{StaticResource BackgroundTertiary}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarBackgroundStart}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}" />
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
</ResourceDictionary>
