<?xml version="1.0" encoding="UTF-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Dashboard-specific styles - these complement Styles.xaml -->

    <!-- Dashboard Page Title (overrides generic PageTitle) -->
    <Style x:Key="DashboardPageTitle" TargetType="Label" BasedOn="{StaticResource PageTitle}">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- Dashboard Primary Button (overrides generic PrimaryButton) -->
    <Style x:Key="DashboardPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="18,10"/>
    </Style>

    <Style x:Key="DashboardSectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource Gray900}"/>
    </Style>

    <Style x:Key="DashboardCaption" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource Gray500}"/>
    </Style>

    <Style x:Key="DashboardSurfaceBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource White}"/>
        <Setter Property="Stroke" Value="{StaticResource PosBorder}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

</ResourceDictionary>
