<?xml version="1.0" encoding="UTF-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page Title -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="#1A1D2E"/>
    </Style>

    <!-- Body Text -->
    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="#6C757D"/>
    </Style>

    <!-- Primary Button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#2C7BE5"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <!-- Metric Card Style -->
    <Style x:Key="MetricCardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="HasShadow" Value="True"/>
    </Style>

    <!-- Stat Label -->
    <Style x:Key="StatLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextColor" Value="#6C757D"/>
    </Style>

    <!-- Stat Value -->
    <Style x:Key="StatValue" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="#1A1D2E"/>
    </Style>

    <!-- Stat Change Positive -->
    <Style x:Key="StatChangePositive" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="#00D97E"/>
    </Style>

    <!-- Stat Change Negative -->
    <Style x:Key="StatChangeNegative" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="#E63757"/>
    </Style>

    <!-- Small Text -->
    <Style x:Key="SmallText" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="#6C757D"/>
    </Style>

    <!-- Chart Container Style -->
    <Style x:Key="ChartContainerStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="HasShadow" Value="True"/>
    </Style>

    <!-- Card Title -->
    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="#1A1D2E"/>
    </Style>

    <!-- Subheader -->
    <Style x:Key="Subheader" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="#1A1D2E"/>
    </Style>

    <!-- Badge Success -->
    <Style x:Key="BadgeSuccess" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="#00D97E"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HasShadow" Value="False"/>
    </Style>

    <!-- Badge Warning -->
    <Style x:Key="BadgeWarning" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="#F6C343"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HasShadow" Value="False"/>
    </Style>

    <!-- Badge Danger -->
    <Style x:Key="BadgeDanger" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="#E63757"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HasShadow" Value="False"/>
    </Style>

    <!-- Badge Text -->
    <Style x:Key="BadgeText" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="White"/>
    </Style>

</ResourceDictionary>
