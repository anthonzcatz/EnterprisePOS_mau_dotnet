    <!-- Primary Button - Responsive -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ButtonPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource ButtonPrimaryText}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="{OnIdiom Phone='12,6', Tablet='14,8', Desktop='16,10'}" />
        <Setter Property="FontSize" Value="{OnIdiom Phone=13, Tablet=14, Desktop=15}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="MinimumHeightRequest" Value="{OnIdiom Phone=36, Tablet=40, Desktop=44}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.8" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Gray300}" />
                            <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Outline Button - Responsive -->
    <Style TargetType="Button" x:Key="OutlineButton">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource ButtonPrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource ButtonPrimary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="{OnIdiom Phone='12,6', Tablet='14,8', Desktop='16,10'}" />
        <Setter Property="FontSize" Value="{OnIdiom Phone=13, Tablet=14, Desktop=15}" />
