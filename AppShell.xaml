<?xml version="1.0" encoding="UTF-8"?>
<Shell
    x:Class="EnterprisePOS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pos="clr-namespace:EnterprisePOS.Features.POS.Views"
    xmlns:dashboard="clr-namespace:EnterprisePOS.Features.Dashboard.Views"
    xmlns:sales="clr-namespace:EnterprisePOS.Features.Sales.Views"
    xmlns:products="clr-namespace:EnterprisePOS.Features.Products.Views"
    xmlns:inventory="clr-namespace:EnterprisePOS.Features.Inventory.Views"
    xmlns:customers="clr-namespace:EnterprisePOS.Features.Customers.Views"
    xmlns:reports="clr-namespace:EnterprisePOS.Features.Reports.Views"
    xmlns:users="clr-namespace:EnterprisePOS.Features.Users.Views"
    xmlns:settings="clr-namespace:EnterprisePOS.Features.Settings.Views"
    Shell.FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False"
    FlyoutBackgroundColor="{StaticResource SidebarBackgroundStart}"
    BackgroundColor="{StaticResource BackgroundSecondary}"
    Title="EnterprisePOS">

    <!-- Sidebar Header -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="88"
              BackgroundColor="{StaticResource SidebarBackgroundStart}"
              Padding="20,18,20,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource Primary}"
                    WidthRequest="42"
                    HeightRequest="42"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    StrokeShape="RoundRectangle 12">
                <Label Text="EP"
                       TextColor="{StaticResource OffBlack}"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <VerticalStackLayout Grid.Column="1"
                                 Margin="12,0,0,0"
                                 VerticalOptions="Center"
                                 Spacing="2">
                <Label Text="EnterprisePOS"
                       TextColor="White"
                       FontSize="16"
                       FontAttributes="Bold"/>
                <Label Text="Enterprise Retail And Restaurant Suite"
                       TextColor="{StaticResource SidebarTextMuted}"
                       FontSize="11"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Navigation -->
    <FlyoutItem Title="Overview" FlyoutDisplayOptions="AsMultipleItems" Route="overview">
        <ShellContent Title="Dashboard"
                      ContentTemplate="{DataTemplate dashboard:DashboardPage}"
                      Route="dashboard"/>
    </FlyoutItem>

    <FlyoutItem Title="Commerce" FlyoutDisplayOptions="AsMultipleItems" Route="commerce">
        <ShellContent Title="Point of Sale"
                      ContentTemplate="{DataTemplate pos:POSPage}"
                      Route="pos"/>
        <ShellContent Title="Sales"
                      ContentTemplate="{DataTemplate sales:SalesPage}"
                      Route="sales"/>
    </FlyoutItem>

    <FlyoutItem Title="Operations" FlyoutDisplayOptions="AsMultipleItems" Route="operations">
        <ShellContent Title="Products"
                      ContentTemplate="{DataTemplate products:ProductsPage}"
                      Route="products"/>
        <ShellContent Title="Inventory"
                      ContentTemplate="{DataTemplate inventory:InventoryPage}"
                      Route="inventory"/>
        <ShellContent Title="Customers"
                      ContentTemplate="{DataTemplate customers:CustomersPage}"
                      Route="customers"/>
    </FlyoutItem>

    <FlyoutItem Title="Insights" FlyoutDisplayOptions="AsMultipleItems" Route="insights">
        <ShellContent Title="Reports"
                      ContentTemplate="{DataTemplate reports:ReportsPage}"
                      Route="reports"/>
    </FlyoutItem>

    <FlyoutItem Title="Administration" FlyoutDisplayOptions="AsMultipleItems" Route="administration">
        <ShellContent Title="Users"
                      ContentTemplate="{DataTemplate users:UsersPage}"
                      Route="users"/>
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate settings:SettingsPage}"
                      Route="settings"/>
    </FlyoutItem>

    <!-- Sidebar Footer -->
    <Shell.FlyoutFooter>
        <StackLayout BackgroundColor="{StaticResource SidebarBackgroundStart}" Padding="20,12" Spacing="0">
            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray800}" Margin="0,0,0,12"/>
            <Label Text="Cross-platform enterprise workspace"
                   TextColor="{StaticResource SidebarTextMuted}"
                   FontSize="11"
                   HorizontalOptions="Center"/>
            <Label Text="Windows · macOS · Android · iOS"
                   TextColor="{StaticResource SidebarTextMuted}"
                   FontSize="10"
                   HorizontalOptions="Center"
                   Margin="0,4,0,0"/>
        </StackLayout>
    </Shell.FlyoutFooter>

</Shell>
