<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EnterprisePOS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:EnterprisePOS.Views"
    Shell.NavBarIsVisible="False"
    Title="Enterprise POS">

    <!-- Minimal stable shell: POS only (avoids WinUI startup crash) -->
    <ShellContent
        Title="POS"
        ContentTemplate="{DataTemplate views:POSPage}"
        Route="pos" />

</Shell>
