<?xml version="1.0" encoding="UTF-8"?>
<Shell
    x:Class="EnterprisePOS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pos="clr-namespace:EnterprisePOS.Features.POS.Views"
    xmlns:dashboard="clr-namespace:EnterprisePOS.Features.Dashboard.Views"
    xmlns:sales="clr-namespace:EnterprisePOS.Features.Sales.Views"
    xmlns:products="clr-namespace:EnterprisePOS.Features.Products.Views"
    xmlns:inventory="clr-namespace:EnterprisePOS.Features.Inventory.Views"
    xmlns:customers="clr-namespace:EnterprisePOS.Features.Customers.Views"
    xmlns:reports="clr-namespace:EnterprisePOS.Features.Reports.Views"
    xmlns:usermgmt="clr-namespace:EnterprisePOS.Features.UserManagement.Views"
    xmlns:settings="clr-namespace:EnterprisePOS.Features.Settings.Views"
    xmlns:categories="clr-namespace:EnterprisePOS.Features.Categories.Views"
    xmlns:units="clr-namespace:EnterprisePOS.Features.Units.Views"
    xmlns:auth="clr-namespace:EnterprisePOS.Features.Auth.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    FlyoutBackgroundColor="Transparent"
    BackgroundColor="{StaticResource BackgroundSecondary}"
    Title="EnterprisePOS">

    <!-- Login Page (Not in Flyout) -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate auth:LoginPage}"
                  Shell.FlyoutItemIsVisible="False"/>

    <!-- Sidebar Header -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="88"
              BackgroundColor="Transparent"
              Padding="20,18,20,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource Primary}"
                    WidthRequest="42"
                    HeightRequest="42"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    StrokeShape="RoundRectangle 12">
                <Label Text="EP"
                       TextColor="{StaticResource White}"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <VerticalStackLayout Grid.Column="1"
                                 Margin="12,0,0,0"
                                 VerticalOptions="Center"
                                 Spacing="2">
                <Label Text="EnterprisePOS"
                       TextColor="{StaticResource Gray900}"
                       FontSize="16"
                       FontAttributes="Bold"/>
                <Label Text="Enterprise Retail And Restaurant Suite"
                       TextColor="{StaticResource Gray500}"
                       FontSize="11"/>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Navigation -->
    <FlyoutItem Title="Dashboard" Route="dashboard">
        <ShellContent Title="Dashboard"
                      ContentTemplate="{DataTemplate dashboard:DashboardPage}"
                      Route="dashboard-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Point of Sale" Route="pos">
        <ShellContent Title="Point of Sale"
                      ContentTemplate="{DataTemplate pos:POSPage}"
                      Route="pos-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Sales" Route="sales">
        <ShellContent Title="Sales"
                      ContentTemplate="{DataTemplate sales:SalesPage}"
                      Route="sales-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Catalog" Icon="inventory_2" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent Title="Products" Icon="inventory_2" ContentTemplate="{DataTemplate products:ProductsPage}" Route="products" />
        <ShellContent Title="Categories" Icon="category" ContentTemplate="{DataTemplate categories:CategoryListPage}" Route="categories" />
        <ShellContent Title="CategoryEditor" ContentTemplate="{DataTemplate categories:CategoryEditorPage}" Route="CategoryEditor" />
        <ShellContent Title="Units" Icon="straighten" ContentTemplate="{DataTemplate units:UnitListPage}" Route="units" />
    </FlyoutItem>

    <FlyoutItem Title="Inventory" Route="inventory">
        <ShellContent Title="Inventory"
                      ContentTemplate="{DataTemplate inventory:InventoryPage}"
                      Route="inventory-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Customers" Route="customers">
        <ShellContent Title="Customers"
                      ContentTemplate="{DataTemplate customers:CustomersPage}"
                      Route="customers-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Reports" Route="reports">
        <ShellContent Title="Reports"
                      ContentTemplate="{DataTemplate reports:ReportsPage}"
                      Route="reports-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Users" Route="user-management">
        <ShellContent Title="Users"
                      ContentTemplate="{DataTemplate usermgmt:UserManagementPage}"
                      Route="user-management-main"/>
    </FlyoutItem>

    <FlyoutItem Title="Settings" Route="settings">
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate settings:SettingsPage}"
                      Route="settings-main"/>
    </FlyoutItem>

    <!-- Sidebar Footer -->
    <Shell.FlyoutFooter>
        <StackLayout BackgroundColor="Transparent" Padding="20,12" Spacing="0">
            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray800}" Margin="0,0,0,12"/>
            <Label Text="Cross-platform enterprise workspace"
                   TextColor="{StaticResource Gray500}"
                   FontSize="11"
                   HorizontalOptions="Center"/>
            <Label Text="Windows · macOS · Android · iOS"
                   TextColor="{StaticResource Gray500}"
                   FontSize="10"
                   HorizontalOptions="Center"
                   Margin="0,4,0,0"/>
        </StackLayout>
    </Shell.FlyoutFooter>

</Shell>
