<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Color.Brand.Primary">#356AE6</Color>
    <Color x:Key="Color.Brand.Secondary">#6E56CF</Color>

    <!-- Surfaces -->
    <Color x:Key="Color.Surface.App">#F4F7FC</Color>
    <Color x:Key="Color.Surface.Card">#FFFFFF</Color>
    <Color x:Key="Color.Surface.Elevated">#EEF3FB</Color>

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#1F2A3D</Color>
    <Color x:Key="Color.Text.Secondary">#4B5B74</Color>
    <Color x:Key="Color.Text.Muted">#73819A</Color>
    <Color x:Key="Color.Text.OnBrand">#FFFFFF</Color>

    <!-- Borders -->
    <Color x:Key="Color.Border.Subtle">#D7E1F0</Color>
    <Color x:Key="Color.Border.Strong">#C5D2E5</Color>

    <!-- Status -->
    <Color x:Key="Color.Success">#1FA66A</Color>
    <Color x:Key="Color.Warning">#C88A24</Color>
    <Color x:Key="Color.Danger">#D95364</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{DynamicResource Color.Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Surface.App" Color="{DynamicResource Color.Surface.App}" />
    <SolidColorBrush x:Key="Brush.Surface.Card" Color="{DynamicResource Color.Surface.Card}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{DynamicResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.OnBrand" Color="{DynamicResource Color.Text.OnBrand}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{DynamicResource Color.Border.Subtle}" />

</ResourceDictionary>
