<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Color.Brand.Primary">#6AA5FF</Color>
    <Color x:Key="Color.Brand.Secondary">#202C3C</Color>

    <!-- Surfaces -->
    <Color x:Key="Color.Surface.App">#121820</Color>
    <Color x:Key="Color.Surface.Card">#1A2330</Color>
    <Color x:Key="Color.Surface.Elevated">#202C3C</Color>

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#E8EEF8</Color>
    <Color x:Key="Color.Text.Secondary">#C4CFDF</Color>
    <Color x:Key="Color.Text.Muted">#93A3B8</Color>
    <Color x:Key="Color.Text.OnBrand">#0E1624</Color>

    <!-- Borders -->
    <Color x:Key="Color.Border.Subtle">#2A3749</Color>
    <Color x:Key="Color.Border.Strong">#36465D</Color>

    <!-- Status -->
    <Color x:Key="Color.Success">#39D98A</Color>
    <Color x:Key="Color.Warning">#E2A23C</Color>
    <Color x:Key="Color.Danger">#FF7D8F</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{DynamicResource Color.Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Surface.App" Color="{DynamicResource Color.Surface.App}" />
    <SolidColorBrush x:Key="Brush.Surface.Card" Color="{DynamicResource Color.Surface.Card}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{DynamicResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.OnBrand" Color="{DynamicResource Color.Text.OnBrand}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{DynamicResource Color.Border.Subtle}" />

</ResourceDictionary>
