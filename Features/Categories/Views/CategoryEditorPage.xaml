<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Categories.ViewModels"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             x:Class="EnterprisePOS.Features.Categories.Views.CategoryEditorPage"
             x:DataType="vm:CategoryEditorViewModel"
             BackgroundColor="{StaticResource Gray100}"
             Title="{Binding EditorTitle}">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                       Title="{Binding EditorTitle}" 
                                       Description="Define category details and hierarchical relationships." />
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource OutlineButtonSmall}" />
                    <Button Text="Save Category" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonSmall}" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24" Spacing="20" MaximumWidthRequest="800" HorizontalOptions="Center">
                <Border BackgroundColor="{StaticResource White}" Padding="24" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                    <VerticalStackLayout Spacing="20">
                        <Label Text="Category Details" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Category Name *" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray700}" />
                            <Entry Text="{Binding Name}" Placeholder="e.g. Beverages" HeightRequest="40" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Parent Category" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray700}" />
                            <Border Stroke="{StaticResource BorderColor}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <Picker ItemsSource="{Binding ParentCategories}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedParent}" Title="Select Parent (Optional)" HeightRequest="40" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Description" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray700}" />
                            <Editor Text="{Binding Description}" Placeholder="Optional category description..." AutoSize="TextChanges" MinimumHeightRequest="80" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Sort Order" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray700}" />
                                <Entry Text="{Binding SortOrder}" Keyboard="Numeric" HeightRequest="40" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8">
                                    <Switch IsToggled="{Binding IsActive}" OnColor="{StaticResource Primary}" />
                                    <Label Text="Active" VerticalOptions="Center" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
