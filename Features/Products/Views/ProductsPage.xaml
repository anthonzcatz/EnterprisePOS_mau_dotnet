<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Products.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Products.Views.ProductsPage"
             x:DataType="vm:ProductsViewModel"
             Title="Products"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <components:AppShellLayout ActiveKey="products" PageTitle="Products">
        <components:AppShellLayout.PageBody>
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Product Catalog" 
                                      Description="Manage your items, pricing, and categories." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="+ Add Product" 
                            Command="{Binding AddProductCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Stats and Filter Bar -->
        <VerticalStackLayout Grid.Row="1" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}" Spacing="{OnIdiom Phone=12, Tablet=16, Desktop=20}">
            <!-- Stats Strip -->
            <Grid ColumnDefinitions="{OnIdiom Phone='*', Tablet='*,*', Desktop='*,*,*,*'}" ColumnSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}">
                <components:MetricCardView Grid.Column="0" Title="Total Items" Value="{Binding Products.Count, StringFormat='{0}'}" Icon="📦" />
                <components:MetricCardView Grid.Column="1" Title="Active" Value="--" Icon="✅" />
                <components:MetricCardView Grid.Column="2" Title="Low Stock" Value="--" Icon="⚠️" IsPositive="False" />
                <components:MetricCardView Grid.Column="3" Title="Out of Stock" Value="--" Icon="❌" IsPositive="False" />
            </Grid>

            <!-- Search and View Toggle -->
            <Border BackgroundColor="{StaticResource White}" Padding="{OnIdiom Phone=6, Tablet=8, Desktop=8}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=12}">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search by name or code..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Toggle View" 
                            Command="{Binding ToggleViewCommand}"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            WidthRequest="{OnIdiom Phone=100, Tablet=120, Desktop=140}" />
                    
                    <Button Grid.Column="2" 
                            Text="Filters" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Main Content -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Products}" Margin="{OnIdiom Phone=16, Tablet=20, Desktop=24}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout 
                        Orientation="Vertical" 
                        Span="{OnIdiom Phone=1, Tablet=2, Desktop=4}" 
                        HorizontalItemSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}" 
                        VerticalItemSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Border Padding="0" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                            <VerticalStackLayout Spacing="0">
                                <Grid HeightRequest="{OnIdiom Phone=120, Tablet=140, Desktop=160}" BackgroundColor="{StaticResource Gray200}">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                    <!-- Placeholder if no image -->
                                    <Label Text="📦" 
                                           FontSize="{OnIdiom Phone=32, Tablet=40, Desktop=48}"
                                           HorizontalOptions="Center" VerticalOptions="Center" 
                                           TextColor="{StaticResource Gray500}" />
                                    
                                    <!-- Badges -->
                                    <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Start" Margin="{OnIdiom Phone=6, Tablet=8, Desktop=8}" Spacing="4">
                                        <Border BackgroundColor="{StaticResource Success}" Padding="{OnIdiom Phone='4,2', Tablet='6,2', Desktop='6,2'}" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                            <Label Text="Active" FontSize="{OnIdiom Phone=9, Tablet=10, Desktop=11}" TextColor="White" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>

                                <VerticalStackLayout Padding="{OnIdiom Phone=10, Tablet=12, Desktop=12}" Spacing="{OnIdiom Phone=2, Tablet=4, Desktop=4}">
                                    <Label Text="{Binding Category.Name}" FontSize="{OnIdiom Phone=10, Tablet=11, Desktop=12}" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                    <Label Text="{Binding Name}" FontSize="{OnIdiom Phone=14, Tablet=16, Desktop=16}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Code}" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray500}" />
                                    
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                        <Label Grid.Column="0" Text="{Binding SellingPrice, StringFormat='₱{0:N2}'}" FontSize="{OnIdiom Phone=16, Tablet=18, Desktop=18}" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                        <Label Grid.Column="1" Text="In Stock" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" VerticalOptions="Center" TextColor="{StaticResource Success}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <components:EmptyStateView Title="No products found" 
                                              Message="Try adjusting your filters or search query." 
                                              ActionText="Clear Search" />
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
            </Grid>
        </components:AppShellLayout.PageBody>
    </components:AppShellLayout>
</ContentPage>
