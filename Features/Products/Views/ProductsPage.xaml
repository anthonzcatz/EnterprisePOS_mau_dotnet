<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Products.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Products.Views.ProductsPage"
             x:DataType="vm:ProductsViewModel"
             Title="Products"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource Gray100}">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="24,20">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Product Catalog" 
                                      Description="Manage your items, pricing, and categories." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="+ Add Product" 
                            Command="{Binding AddProductCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="16,10" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Stats and Filter Bar -->
        <VerticalStackLayout Grid.Row="1" Padding="24,16" Spacing="16">
            <!-- Stats Strip -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                <components:MetricCardView Grid.Column="0" Title="Total Items" Value="{Binding Products.Count, StringFormat='{0}'}" Icon="📦" />
                <components:MetricCardView Grid.Column="1" Title="Active" Value="--" Icon="✅" />
                <components:MetricCardView Grid.Column="2" Title="Low Stock" Value="--" Icon="⚠️" IsPositive="False" />
                <components:MetricCardView Grid.Column="3" Title="Out of Stock" Value="--" Icon="❌" IsPositive="False" />
            </Grid>

            <!-- Search and View Toggle -->
            <Border BackgroundColor="{StaticResource White}" Padding="8" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search by name or code..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Toggle View" 
                            Command="{Binding ToggleViewCommand}"
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}"
                            WidthRequest="120" />
                    
                    <Button Grid.Column="2" 
                            Text="Filters" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Main Content -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Products}" Margin="24,0">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="16" VerticalItemSpacing="16" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Border Padding="0" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <VerticalStackLayout Spacing="0">
                                <Grid HeightRequest="140" BackgroundColor="{StaticResource Gray200}">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                    <!-- Placeholder if no image -->
                                    <Label Text="📦" 
                                           FontSize="40"
                                           HorizontalOptions="Center" VerticalOptions="Center" 
                                           TextColor="{StaticResource Gray500}" />
                                    
                                    <!-- Badges -->
                                    <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Start" Margin="8" Spacing="4">
                                        <Border BackgroundColor="{StaticResource Success}" Padding="6,2" StrokeShape="RoundRectangle 4" StrokeThickness="0">
                                            <Label Text="Active" FontSize="10" TextColor="White" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>

                                <VerticalStackLayout Padding="12" Spacing="4">
                                    <Label Text="{Binding Category.Name}" FontSize="11" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" MaxLines="1" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Code}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                        <Label Grid.Column="0" Text="{Binding SellingPrice, StringFormat='₱{0:N2}'}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                        <Label Grid.Column="1" Text="In Stock" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource Success}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <components:EmptyStateView Title="No products found" 
                                              Message="Try adjusting your filters or search query." 
                                              ActionText="Clear Search" />
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
