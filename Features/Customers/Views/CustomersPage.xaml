<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Customers.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Customers.Views.CustomersPage"
             x:DataType="vm:CustomersViewModel"
             Title="Customers"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource Gray100}">

    <components:AppShellLayout ActiveKey="customers" PageTitle="Customers">
        <components:AppShellLayout.PageBody>
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Customer Directory" 
                                      Description="Manage customer records, tags, and service insights." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="+ Add Customer" 
                            Command="{Binding AddCustomerCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Search and Filters -->
        <VerticalStackLayout Grid.Row="1" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}" Spacing="{OnIdiom Phone=12, Tablet=16, Desktop=20}">
            <Border BackgroundColor="{StaticResource White}" Padding="{OnIdiom Phone=6, Tablet=8, Desktop=8}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=12}">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search by name, code, or phone..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Groups" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Customer List -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Customers}" Margin="{OnIdiom Phone=16, Tablet=20, Desktop=24}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout 
                        Orientation="Vertical" 
                        Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" 
                        HorizontalItemSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}" 
                        VerticalItemSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Customer">
                        <Border Padding="{OnIdiom Phone=12, Tablet=16, Desktop=16}" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{OnIdiom Phone=12, Tablet=16, Desktop=16}">
                                <Border Grid.Column="0" 
                                        WidthRequest="{OnIdiom Phone=44, Tablet=50, Desktop=56}" 
                                        HeightRequest="{OnIdiom Phone=44, Tablet=50, Desktop=56}" 
                                        BackgroundColor="{StaticResource Gray100}" 
                                        StrokeShape="RoundRectangle 24" StrokeThickness="0">
                                    <Label Text="👤" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=28}" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="{OnIdiom Phone=2, Tablet=2, Desktop=4}">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="{OnIdiom Phone=14, Tablet=16, Desktop=16}" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Code}" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray500}" />
                                    
                                    <HorizontalStackLayout Spacing="{OnIdiom Phone=6, Tablet=8, Desktop=8}" Margin="0,4,0,0">
                                        <Label Text="📞" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" VerticalOptions="Center" />
                                        <Label Text="{Binding Phone, FallbackValue='No phone'}" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" VerticalOptions="Center" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>

                                    <Button Text="View Profile" 
                                            Style="{StaticResource LinkButton}"
                                            HorizontalOptions="Start"
                                            Command="{Binding ViewDetailsCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <components:EmptyStateView Title="No customers found" 
                                              Message="Try a different search term or add a new customer." />
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
            </Grid>
        </components:AppShellLayout.PageBody>
    </components:AppShellLayout>
</ContentPage>
