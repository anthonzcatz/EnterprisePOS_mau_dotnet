<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Customers.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Customers.Views.CustomersPage"
             x:DataType="vm:CustomersViewModel"
             Title="Customers"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource Gray100}">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="24,20">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Customer Directory" 
                                      Description="Manage customer records, tags, and service insights." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="+ Add Customer" 
                            Command="{Binding AddCustomerCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="16,10" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Search and Filters -->
        <VerticalStackLayout Grid.Row="1" Padding="24,16" Spacing="16">
            <Border BackgroundColor="{StaticResource White}" Padding="8" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search by name, code, or phone..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Groups" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Customer List -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Customers}" Margin="24,0,24,24">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="16" VerticalItemSpacing="16" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Customer">
                        <Border Padding="16" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                <Border Grid.Column="0" 
                                        WidthRequest="50" HeightRequest="50" 
                                        BackgroundColor="{StaticResource Gray100}" 
                                        StrokeShape="RoundRectangle 25" StrokeThickness="0">
                                    <Label Text="👤" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Code}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    
                                    <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                                        <Label Text="📞" FontSize="12" VerticalOptions="Center" />
                                        <Label Text="{Binding Phone, FallbackValue='No phone'}" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>

                                    <Button Text="View Profile" 
                                            FontSize="12"
                                            Padding="0"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource Primary}"
                                            HorizontalOptions="Start"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomersViewModel}}, Path=ViewDetailsCommand}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <components:EmptyStateView Title="No customers found" 
                                              Message="Try a different search term or add a new customer." />
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
