<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             x:Class="EnterprisePOS.Features.POS.Views.POSPage"
             x:Name="Page"
             Title="EnterprisePOS"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <Grid x:Name="LayoutRoot">

        <!-- Content Container -->
        <Grid >
            <!-- Tablet / laptop â€” navbar row 0; catalog + cart split row 1 -->
            <Grid x:Name="WideLayout"
                  IsVisible="True"
                  ColumnSpacing="0"
                  RowDefinitions="Auto,*"
                  RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding CartColumnWidth}" />
            </Grid.ColumnDefinitions>

            <components:PosSidebarView Grid.RowSpan="2"
                                       Grid.Column="0"
                                       NavItems="{Binding NavItems}"
                                       IsCollapsed="{Binding IsSidebarCollapsed}"
                                       IsVisible="{Binding ShowSidebar}"
                                       ToggleCommand="{Binding ToggleSidebarCommand}"
                                       NavigateCommand="{Binding NavigateCommand}" />

            <!-- Top navbar â€” compact, full width -->
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="20,10,18,10">
                <Grid RowDefinitions="Auto"
                      RowSpacing="0">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto"
                          ColumnSpacing="12"
                          VerticalOptions="Center">
                        <!-- Burger menu (visible when sidebar is hidden on tablet) -->
                        <Border Grid.Column="0"
                                WidthRequest="42"
                                HeightRequest="42"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding ShowSidebar}" Value="True">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding ShowSidebar}" Value="False">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenMobileSidebarCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="☰"
                                   FontSize="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="0"
                                             VerticalOptions="Center"
                                             WidthRequest="{Binding DesktopIdentityWidth}"
                                             Margin="0,0,4,0">
                            <Label Text="{Binding StoreName}"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                            <Label Text="{Binding StoreTagline}"
                                   FontSize="11"
                                   TextColor="{StaticResource PosTextMuted}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1" />
                        </VerticalStackLayout>
                        <SearchBar Grid.Column="2"
                                   Style="{StaticResource PosSearchBarCompact}"
                                   Placeholder="Search coffee, pastries, bites..."
                                   Text="{Binding SearchText}"
                                   VerticalOptions="Center" />
                        <Button Grid.Column="3"
                                Text="Open Tab"
                                Style="{StaticResource PosCreateNoteButton}"
                                IsVisible="{Binding ShowDesktopUtilityActions}"
                                VerticalOptions="Center" />
                        <!-- Chat icon -->
                        <Border Grid.Column="4"
                                WidthRequest="36"
                                HeightRequest="36"
                                Stroke="{StaticResource PosBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource White}"
                                IsVisible="{Binding ShowDesktopUtilityActions}"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="&#x1F4AC;"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <!-- Bell icon -->
                        <Border Grid.Column="5"
                                WidthRequest="36"
                                HeightRequest="36"
                                Stroke="{StaticResource PosBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource White}"
                                IsVisible="{Binding ShowDesktopUtilityActions}"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="&#x1F514;"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                        <!-- Cashier profile -->
                        <HorizontalStackLayout Grid.Column="6"
                                               Spacing="8"
                                               VerticalOptions="Center">
                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleProfileMenuCommand}" />
                            </HorizontalStackLayout.GestureRecognizers>
                            <Border StrokeThickness="0"
                                    HeightRequest="36"
                                    WidthRequest="36"
                                    BackgroundColor="{StaticResource ButtonPrimary}"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>
                                <Label Text="{Binding CashierInitials}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource ButtonPrimaryText}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Spacing="0"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding CashierName}"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding CashierRole}"
                                       FontSize="11"
                                       TextColor="{StaticResource PosTextMuted}" />
                            </VerticalStackLayout>
                            <Label Text="&#x25BE;"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center"
                                   Margin="2,0,0,0" />
                        </HorizontalStackLayout>
                    </Grid>
                </Grid>
            </Border>

            <!-- Catalog: categories only here (not shared with cart height) -->
            <Grid Grid.Row="1"
                  Grid.Column="1"
                  RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="0"
                  BackgroundColor="{StaticResource BackgroundSecondary}"
                  Padding="20,0,12,0">
                <BoxView Grid.Row="0"
                         HeightRequest="1"
                         Color="{StaticResource PosBorder}"
                         Margin="0,0,0,8" />
                <Border Grid.Row="1"
                        BackgroundColor="{StaticResource White}"
                        StrokeThickness="0"
                        HeightRequest="50"
                        Padding="0"
                        Margin="0,0,0,8">
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Default"
                                VerticalScrollBarVisibility="Never">
                        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Categories}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Padding="12,0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <components:PosCategoryTabView Title="{Binding Name}"
                                                                   Icon="{Binding Icon}"
                                                                   IsSelected="{Binding IsSelected}"
                                                                   SelectCommand="{Binding Source={x:Reference Page}, Path=BindingContext.SelectCategoryCommand}"
                                                                   CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </Border>
                <BoxView Grid.Row="2"
                         HeightRequest="1"
                         Color="{StaticResource PosBorder}"
                         Margin="0,0,0,0" />
                <CollectionView Grid.Row="3"
                                ItemsSource="{Binding Products}"
                                SelectionMode="None"
                                Margin="0,8,0,16">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="{Binding ProductGridSpan}"
                                         HorizontalItemSpacing="12"
                                         VerticalItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <components:PosProductCardView Title="{Binding Name}"
                                                           Description="{Binding Description}"
                                                           PriceText="{Binding Price, StringFormat='₱{0:F2}'}"
                                                           StockBadgeText="{Binding StockCount, StringFormat='{0} Stock'}"
                                                           ImageSource="{Binding Image}"
                                                           CommandParameter="{Binding .}"
                                                           AddCommand="{Binding Source={x:Reference Page}, Path=BindingContext.AddToCartCommand}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Cart â€” full height directly under cashier navbar -->
            <Grid Grid.Row="1"
                  Grid.Column="2"
                  BackgroundColor="{StaticResource BackgroundSecondary}"
                  Padding="12,0,18,0"
                  RowDefinitions="*,Auto,Auto,Auto,Auto"
                  RowSpacing="12">
                <!-- Cart card: header + items in ONE bordered panel (fills column height) -->
                <Border Grid.Row="0"
                        VerticalOptions="Fill"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="14"
                        Margin="0,12,0,16"
                        StrokeShape="RoundRectangle 16">
                    <Grid RowDefinitions="Auto,Auto,*"
                          VerticalOptions="Fill"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <Label Text="Order Details"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    Stroke="{StaticResource PosBorder}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource White}"
                                    Padding="8,4"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ResetOrderCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="4"
                                                       VerticalOptions="Center">
                                    <Label Text="🗑️"
                                           FontSize="10"
                                           VerticalOptions="Center" />
                                    <Label Text="Reset Order"
                                           FontSize="11"
                                           TextColor="{StaticResource Gray900}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                        <BoxView Grid.Row="1"
                                 HeightRequest="1"
                                 Color="{StaticResource PosBorder}" />
                        <ScrollView Grid.Row="2"
                                    VerticalOptions="Fill"
                                    VerticalScrollBarVisibility="Default">
                            <VerticalStackLayout Spacing="0"
                                                 BindableLayout.ItemsSource="{Binding CartItems}">
                                <BindableLayout.EmptyView>
                                    <Grid VerticalOptions="Center"
                                          HorizontalOptions="Center">
                                        <VerticalStackLayout Spacing="6"
                                                             VerticalOptions="Center"
                                                             HorizontalOptions="Center">
                                            <Label Text="🛒"
                                                   FontSize="40"
                                                   HorizontalOptions="Center" />
                                            <Label Text="Your cart is empty"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Gray900}"
                                                   HorizontalOptions="Center" />
                                            <Label Text="Add items to get started"
                                                   FontSize="11"
                                                   TextColor="{StaticResource PosTextMuted}"
                                                   HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </BindableLayout.EmptyView>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <components:PosCartLineView Title="{Binding Name}"
                                                                    Description="{Binding Description}"
                                                                    PriceText="{Binding LineTotal, StringFormat='₱{0:F2}' }"
                                                                    QuantityText="{Binding Quantity}"
                                                                    Size="{Binding Size}"
                                                                    Color="{Binding Color}"
                                                                    TotalText="{Binding LineTotal, StringFormat='Total ₱{0:F2}' }"
                                                                    ImageSource="{Binding Image}"
                                                                    CommandParameter="{Binding .}"
                                                                    IncreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.IncreaseQuantityCommand}"
                                                                    DecreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.DecreaseQuantityCommand}"
                                                                    DeleteCommand="{Binding Source={x:Reference Page}, Path=BindingContext.DeleteCartItemCommand}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="12"
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="&#x1F381;"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="0"
                                             VerticalOptions="Center"
                                             Margin="8,0">
                            <Label Text="Welcome Discount (10%)"
                                   FontAttributes="Bold"
                                   FontSize="12" />
                            <Label Text="Discount applied automatically"
                                   FontSize="11"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource PosTextMuted}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2"
                                Text="Change Promo"
                                BackgroundColor="{StaticResource ButtonPrimary}"
                                TextColor="{StaticResource ButtonPrimaryText}"
                                Padding="10,4"
                                FontSize="11"
                                HeightRequest="34"
                                MinimumHeightRequest="34"
                                CornerRadius="14"
                                BorderWidth="0" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Sub-Total" TextColor="{StaticResource PosTextMuted}" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding SubTotal, StringFormat='₱{0:F2}'}" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tax (12%)" TextColor="{StaticResource PosTextMuted}" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding TaxAmount, StringFormat='₱{0:F2}'}" FontSize="13" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Discount" TextColor="{StaticResource PosTextMuted}" FontSize="13" />
                            <Label Grid.Column="1" Text="{Binding DiscountAmount, StringFormat='-₱{0:F2}'}" FontSize="13" TextColor="{StaticResource Primary}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource PosBorder}" Margin="0,4" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Total Payment" FontAttributes="Bold" FontSize="15" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalPayment, StringFormat='₱{0:F2}'}"
                                   FontAttributes="Bold"
                                   FontSize="17"
                                   TextColor="{StaticResource Gray900}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="3"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="12"
                        StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <Border WidthRequest="34"
                                HeightRequest="34"
                                BackgroundColor="{StaticResource SuccessLight}"
                                StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding PaymentMethodIcon}"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="{Binding PaymentMethodLabel}"
                               FontAttributes="Bold"
                               FontSize="14"
                               TextColor="{StaticResource Gray900}"
                               VerticalOptions="Center"
                               Margin="8,0" />
                        <Border Grid.Column="2"
                                Padding="9,4"
                                Stroke="{StaticResource PosBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource White}"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangePaymentMethodCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Change"
                                   FontSize="11"
                                   TextColor="{StaticResource PosTextMuted}" />
                        </Border>
                    </Grid>
                </Border>

                <Button Grid.Row="4"
                        Text="&#x1F6CD; Place Order"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ContinueCommand}" />
            </Grid>
        </Grid>

        <!-- Mobile sidebar overlay - at root level to float above all layouts -->
        <Grid IsVisible="{Binding IsMobileSidebarOpen}"
              ZIndex="10">
            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseMobileSidebarCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border HorizontalOptions="Start"
                    VerticalOptions="Fill"
                    WidthRequest="{Binding MobileSidebarWidth}"
                    BackgroundColor="{StaticResource BackgroundSecondary}"
                    StrokeThickness="0"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          Padding="16,16,16,10"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="{StaticResource BackgroundSecondary}">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="1"
                                             VerticalOptions="Center">
                            <Label Text="POS Navigation"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Text="Select a workspace"
                                   FontSize="10"
                                   TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                WidthRequest="32"
                                HeightRequest="32"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource PosDangerRed}"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseMobileSidebarCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕"
                                   FontSize="12"
                                   TextColor="{StaticResource White}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <components:PosSidebarView Grid.Row="1"
                                               NavItems="{Binding NavItems}"
                                               IsCollapsed="{Binding IsSidebarCollapsed}"
                                               ToggleCommand="{Binding ToggleSidebarCommand}"
                                               NavigateCommand="{Binding NavigateCommand}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Desktop profile menu overlay - at root level to float above all layouts -->
        <Grid x:Name="DesktopProfileMenuContainer"
              IsVisible="{Binding IsProfileMenuOpen}"
              ZIndex="11"
              RowSpacing="0"
              ColumnSpacing="0">
            <BoxView BackgroundColor="#00000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseProfileMenuCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,56,30,0"
                    WidthRequest="220"
                    BackgroundColor="{StaticResource White}"
                    Stroke="{StaticResource PosBorder}"
                    StrokeThickness="1"
                    Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Cashier quick actions"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PosTextMuted}" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ProfileMenuItems}"
                                         Spacing="4">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{StaticResource Gray100}"
                                        StrokeThickness="0"
                                        Padding="10,9"
                                        StrokeShape="RoundRectangle 12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference Page}, Path=BindingContext.ProfileMenuCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10"
                                          VerticalOptions="Center">
                                        <Label Grid.Column="0"
                                               Text="{Binding Glyph}"
                                               FontSize="14"
                                               VerticalOptions="Center"
                                               TextColor="{StaticResource Gray900}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="12"
                                               TextColor="{StaticResource Gray900}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Phone -->
        <Grid x:Name="NarrowLayout" IsVisible="True">
            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="12" Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Border Grid.Column="0"
                                Style="{StaticResource PosIconButton}"
                                WidthRequest="40"
                                HeightRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenMobileSidebarCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="☰"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="1"
                                             VerticalOptions="Center">
                            <Label Text="{Binding StoreName}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Text="{Binding StoreTagline}"
                                   FontSize="12"
                                   TextColor="{StaticResource PosTextMuted}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource PosBorder}"
                                StrokeThickness="1"
                                Padding="8,6"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleProfileMenuCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="6"
                                  VerticalOptions="Center">
                                <Border Grid.Column="0"
                                        WidthRequest="28"
                                        HeightRequest="28"
                                        BackgroundColor="{StaticResource ButtonPrimary}"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding CashierInitials}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource ButtonPrimaryText}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding CashierName}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Gray900}" />
                                    <Label Text="{Binding CashierRole}"
                                           FontSize="9"
                                           TextColor="{StaticResource PosTextMuted}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="▾"
                                       FontSize="10"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- SearchBar with icon and cart button -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0" HeightRequest="44">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource PosBorder}"
                                StrokeThickness="1"
                                Padding="12,0"
                                StrokeShape="RoundRectangle 10"
                                VerticalOptions="Center">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalOptions="Center">
                                <Label Grid.Column="0"
                                       Text="🔍"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource Gray700}" />
                                <Entry Grid.Column="1"
                                       Placeholder="Search..."
                                       Text="{Binding SearchText}"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource Gray900}"
                                       PlaceholderColor="{StaticResource Gray400}" />
                            </Grid>
                        </Border>

                        <!-- Cart Toggle Button -->
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource ButtonPrimary}"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                Padding="8,0"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleMobileCartCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="🛒" FontSize="18" VerticalOptions="Center" />
                                <Border BackgroundColor="{StaticResource Danger}"
                                        StrokeThickness="2"
                                        Stroke="White"
                                        Padding="6,2"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding CartItemCount}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="40,*,40"
                          ColumnSpacing="8"
                          HeightRequest="58">
                        <Border Grid.Column="0"
                                Style="{StaticResource PosIconButton}"
                                WidthRequest="36"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource White}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMobileCategoryScrollLeft" />
                            </Border.GestureRecognizers>
                            <Label Text="‹"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                        </Border>

                        <CollectionView x:Name="MobileCategoryStrip"
                                        Grid.Column="1"
                                        ItemsSource="{Binding Categories}"
                                        HeightRequest="58"
                                        SelectionMode="None"
                                        HorizontalScrollBarVisibility="Never"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="0" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <components:PosCategoryTabView Title="{Binding Name}"
                                                                   Icon="{Binding Icon}"
                                                                   IsSelected="{Binding IsSelected}"
                                                                   SelectCommand="{Binding Source={x:Reference Page}, Path=BindingContext.SelectCategoryCommand}"
                                                                   CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border Grid.Column="2"
                                Style="{StaticResource PosIconButton}"
                                WidthRequest="36"
                                HeightRequest="36"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource White}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMobileCategoryScrollRight" />
                            </Border.GestureRecognizers>
                            <Label Text="›"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Gray900}" />
                        </Border>
                    </Grid>

                    <CollectionView ItemsSource="{Binding Products}"
                                    SelectionMode="None"
                                    HeightRequest="{Binding MobileProductListHeight}"
                                    VerticalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="{Binding MobileProductGridSpan}"
                                             HorizontalItemSpacing="10"
                                             VerticalItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <components:PosProductCardView Title="{Binding Name}"
                                                               Description="{Binding Description}"
                                                               PriceText="{Binding Price, StringFormat='₱{0:F2}'}"
                                                               StockBadgeText="{Binding StockCount, StringFormat='{0} Stock'}"
                                                               ImageSource="{Binding Image}"
                                                               CommandParameter="{Binding .}"
                                                               AddCommand="{Binding Source={x:Reference Page}, Path=BindingContext.AddToCartCommand}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Detail Items" Style="{StaticResource PosSectionTitle}" />
                    <Border BackgroundColor="{StaticResource White}"
                            Stroke="{StaticResource PosBorder}"
                            StrokeThickness="1"
                            Padding="12"
                            StrokeShape="RoundRectangle 16">
                        <CollectionView ItemsSource="{Binding CartItems}"
                                        SelectionMode="None"
                                        HeightRequest="{Binding MobileCartListHeight}"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <components:PosCartLineView Title="{Binding Name}"
                                                                Description="{Binding Description}"
                                                                PriceText="{Binding LineTotal, StringFormat='₱{0:F2}'}"
                                                                QuantityText="{Binding Quantity}"
                                                                ImageSource="{Binding Image}"
                                                                CommandParameter="{Binding .}"
                                                                IncreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.IncreaseQuantityCommand}"
                                                                DecreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.DecreaseQuantityCommand}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <Button Text="Place an Order"
                            Style="{StaticResource PosPrimaryButton}"
                            Command="{Binding PlaceOrderCommand}" />
                </VerticalStackLayout>
            </ScrollView>

            <Grid IsVisible="{Binding IsProfileMenuOpen}"
                  ZIndex="12">
                <BoxView BackgroundColor="#00000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseProfileMenuCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Border HorizontalOptions="End"
                        VerticalOptions="Start"
                        Margin="0,56,12,0"
                        WidthRequest="220"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Cashier quick actions"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PosTextMuted}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ProfileMenuItems}"
                                             Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{StaticResource Gray100}"
                                            StrokeThickness="0"
                                            Padding="10,9"
                                            StrokeShape="RoundRectangle 12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference Page}, Path=BindingContext.ProfileMenuCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10"
                                              VerticalOptions="Center">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Glyph}"
                                                   FontSize="14"
                                                   VerticalOptions="Center"
                                                   TextColor="{StaticResource Gray900}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray900}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

        </Grid>
        </Grid>

        <!-- Mobile Cart Overlay -->
        <Grid x:Name="MobileCartOverlay"
              IsVisible="{Binding IsMobileCartOpen}"
              ZIndex="1000"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <Border HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Margin="0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0" Padding="16" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Cart" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            <Label Text="{Binding CartItemCount, StringFormat='{0} items'}" FontSize="12" TextColor="{StaticResource PosTextMuted}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="32" HeightRequest="32" BackgroundColor="{StaticResource PosDangerRed}" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleMobileCartCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="12" TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Default">
                        <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding CartItems}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <components:PosCartLineView Title="{Binding Name}"
                                                                Description="{Binding Description}"
                                                                PriceText="{Binding LineTotal, StringFormat='₱{0:F2}'}"
                                                                QuantityText="{Binding Quantity}"
                                                                Size="{Binding Size}"
                                                                Color="{Binding Color}"
                                                                TotalText="{Binding LineTotal, StringFormat='Total ₱{0:F2}'}"
                                                                ImageSource="{Binding Image}"
                                                                CommandParameter="{Binding .}"
                                                                IncreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.IncreaseQuantityCommand}"
                                                                DecreaseCommand="{Binding Source={x:Reference Page}, Path=BindingContext.DecreaseQuantityCommand}"
                                                                DeleteCommand="{Binding Source={x:Reference Page}, Path=BindingContext.DeleteCartItemCommand}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                    <Border Grid.Row="2" Padding="16" BackgroundColor="{StaticResource White}" Stroke="{StaticResource PosBorder}" StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Total Payment" FontAttributes="Bold" FontSize="15" />
                                <Label Grid.Column="1" Text="{Binding TotalPayment, StringFormat='₱{0:F2}'}" FontAttributes="Bold" FontSize="17" TextColor="{StaticResource Gray900}" />
                            </Grid>
                            <Button Text="🛒 Place Order" Style="{StaticResource PrimaryButton}" Command="{Binding ToggleMobileCheckoutCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Mobile Checkout Modal -->
        <Grid x:Name="MobileCheckoutModal"
              IsVisible="{Binding IsMobileCheckoutOpen}"
              ZIndex="2000"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="{Binding CheckoutModalWidth}"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Margin="20"
                    StrokeShape="RoundRectangle 20">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">
                    <Grid Grid.Row="0" Padding="20" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Checkout" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            <Label Text="Complete your order" FontSize="13" TextColor="{StaticResource PosTextMuted}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="32" HeightRequest="32" BackgroundColor="{StaticResource PosDangerRed}" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleMobileCheckoutCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="12" TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource PosBorder}" />
                    <ScrollView Grid.Row="2" VerticalScrollBarVisibility="Default">
                        <VerticalStackLayout Padding="20" Spacing="16">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Order Summary" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Gray900}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Sub-Total" TextColor="{StaticResource PosTextMuted}" FontSize="14" />
                                    <Label Grid.Column="1" Text="{Binding SubTotal, StringFormat='₱{0:F2}'}" FontSize="14" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Tax (12%)" TextColor="{StaticResource PosTextMuted}" FontSize="14" />
                                    <Label Grid.Column="1" Text="{Binding TaxAmount, StringFormat='₱{0:F2}'}" FontSize="14" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Discount" TextColor="{StaticResource PosTextMuted}" FontSize="14" />
                                    <Label Grid.Column="1" Text="{Binding DiscountAmount, StringFormat='-₱{0:F2}'}" FontSize="14" TextColor="{StaticResource Primary}" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource PosBorder}" Margin="0,8" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Total Payment" FontAttributes="Bold" FontSize="16" />
                                    <Label Grid.Column="1"
                                           Text="{Binding TotalPayment, StringFormat='₱{0:F2}'}"
                                           FontAttributes="Bold"
                                           FontSize="18"
                                           TextColor="{StaticResource Gray900}" />
                                </Grid>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Payment Method" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Gray900}" />
                                <Border BackgroundColor="{StaticResource Gray100}" StrokeThickness="0" Padding="16" StrokeShape="RoundRectangle 12">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                                        <Label Text="{Binding PaymentMethodIcon}" FontSize="20" />
                                        <Label Grid.Column="1" Text="{Binding PaymentMethodLabel}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource Gray900}" />
                                        <Border Grid.Column="2" Padding="8,4" Stroke="{StaticResource PosBorder}" StrokeThickness="1" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ChangePaymentMethodCommand}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="Change" FontSize="12" TextColor="{StaticResource PosTextMuted}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                    <Border Grid.Row="3" Padding="20" BackgroundColor="{StaticResource White}" Stroke="{StaticResource PosBorder}" StrokeThickness="1">
                        <Button Text="✓ Confirm Order" Style="{StaticResource PrimaryButton}" Command="{Binding ContinueCommand}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>







