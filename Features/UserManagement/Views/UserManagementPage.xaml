<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.UserManagement.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Features.UserManagement.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.UserManagement.Views.UserManagementPage"
             x:DataType="vm:UserManagementViewModel"
             x:Name="Page"
             Title="Users"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <components:AppShellLayout ActiveKey="user-management" PageTitle="Users">
        <components:AppShellLayout.PageBody>
            <Grid x:Name="LayoutRoot">

                <Grid x:Name="WideLayout"
                      IsVisible="True"
                      RowDefinitions="Auto,Auto,*"
                      RowSpacing="0">

                    <Border Grid.Row="0"
                            BackgroundColor="{StaticResource White}"
                            StrokeThickness="0"
                            Padding="28,22">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Users"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="Manage staff access, roles, branches, and security settings."
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="+ Add User"
                                    Clicked="OnAddUserClicked"
                                    Style="{StaticResource PrimaryButtonSmall}"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout Grid.Row="1"
                                         Padding="24,18"
                                         Spacing="16">
                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="14">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Team Members" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding TotalUsersText}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Active" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding ActiveUsersText}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Admins" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding AdminUsersText}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="3" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="2FA Enabled" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding TwoFactorUsersText}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Warning}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="{StaticResource White}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 8"
                                Padding="10">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                                <SearchBar Grid.Column="0"
                                           Placeholder="Search by name, username, email, role, or branch"
                                           Text="{Binding SearchQuery}"
                                           BackgroundColor="Transparent" />
                                <Button Grid.Column="1"
                                        Text="Cards"
                                        Command="{Binding ShowCardViewCommand}"
                                        Style="{StaticResource OutlineButtonSmall}" />
                                <Button Grid.Column="2"
                                        Text="List"
                                        Command="{Binding ShowListViewCommand}"
                                        Style="{StaticResource OutlineButtonSmall}" />
                                <Button Grid.Column="3"
                                        Text="Refresh"
                                        Command="{Binding RefreshCommand}"
                                        Style="{StaticResource OutlineButtonSmall}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <RefreshView Grid.Row="2"
                                 Command="{Binding RefreshCommand}"
                                 IsRefreshing="{Binding IsBusy}"
                                 Margin="24,0,24,24">
                        <Grid>
                        <CollectionView ItemsSource="{Binding Users}"
                                        IsVisible="{Binding IsCardView}">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="14" VerticalItemSpacing="14" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserModel">
                                    <Border BackgroundColor="{StaticResource White}"
                                            Stroke="{StaticResource BorderColor}"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="16">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border Grid.Column="0"
                                                        WidthRequest="48"
                                                        HeightRequest="48"
                                                        BackgroundColor="{StaticResource Primary}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 24">
                                                    <Label Text="{Binding Initials}"
                                                           FontAttributes="Bold"
                                                           TextColor="{StaticResource White}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="{Binding FullName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                                    <Label Text="{Binding Email}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                                </VerticalStackLayout>
                                                <Border Grid.Column="2"
                                                        BackgroundColor="{StaticResource SuccessLight}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 8"
                                                        Padding="10,5"
                                                        VerticalOptions="Start">
                                                    <Label Text="{Binding Status}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="Username" FontSize="11" TextColor="{StaticResource Gray500}" />
                                                    <Label Text="{Binding Username}" FontSize="13" TextColor="{StaticResource Gray900}" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="Role" FontSize="11" TextColor="{StaticResource Gray500}" />
                                                    <Label Text="{Binding Role}" FontSize="13" TextColor="{StaticResource Gray900}" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="2" Spacing="2">
                                                    <Label Text="Branch" FontSize="11" TextColor="{StaticResource Gray500}" />
                                                    <Label Text="{Binding Branch}" FontSize="13" TextColor="{StaticResource Gray900}" />
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                                    <Border BackgroundColor="{StaticResource PrimaryLight}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="8,4" IsVisible="{Binding IsAdmin}">
                                                        <Label Text="Admin" FontSize="11" TextColor="{StaticResource Primary}" />
                                                    </Border>
                                                    <Border BackgroundColor="{StaticResource Gray100}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="8,4" IsVisible="{Binding HasTwoFactor}">
                                                        <Label Text="2FA" FontSize="11" TextColor="{StaticResource Gray700}" />
                                                    </Border>
                                                    <Label Text="{Binding CreatedAtText}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                                    <Button Text="Update"
                                                            Command="{Binding BindingContext.EditUserCommand, Source={x:Reference Page}}"
                                                            CommandParameter="{Binding .}"
                                                            Style="{StaticResource OutlineButtonSmall}" />
                                                    <Button Text="Delete"
                                                            Command="{Binding BindingContext.DeleteUserCommand, Source={x:Reference Page}}"
                                                            CommandParameter="{Binding .}"
                                                            Style="{StaticResource OutlineButtonSmall}"
                                                            BorderColor="{StaticResource Danger}"
                                                            TextColor="{StaticResource Danger}" />
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Spacing="12" Padding="0,70" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="No users found" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Gray900}" HorizontalOptions="Center" />
                                    <Label Text="Create a staff account to start managing access." FontSize="14" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                                    <Button Text="+ Add User" Clicked="OnAddUserClicked" Style="{StaticResource PrimaryButtonSmall}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <CollectionView ItemsSource="{Binding Users}"
                                        IsVisible="{Binding IsListView}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.Header>
                                <Border BackgroundColor="{StaticResource Gray100}"
                                        Stroke="{StaticResource BorderColor}"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="14,10"
                                        Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="2*,*,*,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="User" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                                        <Label Grid.Column="1" Text="Role" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                                        <Label Grid.Column="2" Text="Branch" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                                        <Label Grid.Column="3" Text="Status" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                                        <Label Grid.Column="4" Text="Actions" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                                    </Grid>
                                </Border>
                            </CollectionView.Header>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserModel">
                                    <Border BackgroundColor="{StaticResource White}"
                                            Stroke="{StaticResource BorderColor}"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="14">
                                        <Grid ColumnDefinitions="2*,*,*,*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="{Binding FullName}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                                <Label Text="{Binding Email}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding Role}" FontSize="13" TextColor="{StaticResource Gray900}" VerticalOptions="Center" />
                                            <Label Grid.Column="2" Text="{Binding Branch}" FontSize="13" TextColor="{StaticResource Gray900}" VerticalOptions="Center" />
                                            <Label Grid.Column="3" Text="{Binding Status}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Success}" VerticalOptions="Center" />
                                            <HorizontalStackLayout Grid.Column="4" Spacing="8">
                                                <Button Text="Update"
                                                        Command="{Binding BindingContext.EditUserCommand, Source={x:Reference Page}}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource OutlineButtonSmall}" />
                                                <Button Text="Delete"
                                                        Command="{Binding BindingContext.DeleteUserCommand, Source={x:Reference Page}}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource OutlineButtonSmall}"
                                                        BorderColor="{StaticResource Danger}"
                                                        TextColor="{StaticResource Danger}" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        </Grid>
                    </RefreshView>
                </Grid>

                <Grid x:Name="NarrowLayout"
                      IsVisible="False"
                      RowDefinitions="Auto,Auto,*"
                      RowSpacing="0">
                    <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="16">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                            <VerticalStackLayout Grid.Row="0" Spacing="2">
                                <Label Text="Users" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                <Label Text="Staff access and security" FontSize="13" TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Button Grid.Row="1" Text="+ Add User" Clicked="OnAddUserClicked" Style="{StaticResource PrimaryButtonSmall}" />
                        </Grid>
                    </Border>

                    <VerticalStackLayout Grid.Row="1" Padding="16,12" Spacing="12">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="14">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Users" FontSize="11" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding TotalUsersText}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="14">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Active" FontSize="11" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding ActiveUsersText}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                        <Border BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="8">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                <SearchBar Grid.Row="0" Placeholder="Search users" Text="{Binding SearchQuery}" BackgroundColor="Transparent" />
                                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button Grid.Column="0" Text="Cards" Command="{Binding ShowCardViewCommand}" Style="{StaticResource OutlineButtonSmall}" />
                                    <Button Grid.Column="1" Text="List" Command="{Binding ShowListViewCommand}" Style="{StaticResource OutlineButtonSmall}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}" Margin="16,0,16,16">
                        <Grid>
                        <CollectionView ItemsSource="{Binding Users}"
                                        IsVisible="{Binding IsCardView}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserModel">
                                    <Border BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="14">
                                        <VerticalStackLayout Spacing="12">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" BackgroundColor="{StaticResource Primary}" StrokeThickness="0" StrokeShape="RoundRectangle 22">
                                                    <Label Text="{Binding Initials}" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="{Binding FullName}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                                    <Label Text="{Binding Email}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2" Text="{Binding Status}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Success}" VerticalOptions="Start" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding Role}" FontSize="13" TextColor="{StaticResource Gray900}" />
                                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Branch}" FontSize="13" TextColor="{StaticResource Gray900}" />
                                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding Username}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding CreatedAtText}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Button Grid.Column="0"
                                                        Text="Update"
                                                        Command="{Binding BindingContext.EditUserCommand, Source={x:Reference Page}}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource OutlineButtonSmall}" />
                                                <Button Grid.Column="1"
                                                        Text="Delete"
                                                        Command="{Binding BindingContext.DeleteUserCommand, Source={x:Reference Page}}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource OutlineButtonSmall}"
                                                        BorderColor="{StaticResource Danger}"
                                                        TextColor="{StaticResource Danger}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Spacing="12" Padding="0,60" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="No users found" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Gray900}" HorizontalOptions="Center" />
                                    <Label Text="Create a staff account to continue." FontSize="13" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <CollectionView ItemsSource="{Binding Users}"
                                        IsVisible="{Binding IsListView}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:UserModel">
                                    <Border BackgroundColor="{StaticResource White}" Stroke="{StaticResource BorderColor}" StrokeShape="RoundRectangle 8" Padding="12">
                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="{Binding FullName}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                                    <Label Text="{Binding Email}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1" Text="{Binding Status}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Label Grid.Column="0" Text="{Binding Role}" FontSize="12" TextColor="{StaticResource Gray900}" />
                                                <Label Grid.Column="1" Text="{Binding Branch}" FontSize="12" TextColor="{StaticResource Gray900}" />
                                            </Grid>
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Button Grid.Column="0" Text="Update" Command="{Binding BindingContext.EditUserCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" Style="{StaticResource OutlineButtonSmall}" />
                                                <Button Grid.Column="1" Text="Delete" Command="{Binding BindingContext.DeleteUserCommand, Source={x:Reference Page}}" CommandParameter="{Binding .}" Style="{StaticResource OutlineButtonSmall}" BorderColor="{StaticResource Danger}" TextColor="{StaticResource Danger}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        </Grid>
                    </RefreshView>
                </Grid>
            </Grid>
        </components:AppShellLayout.PageBody>
    </components:AppShellLayout>
</ContentPage>
