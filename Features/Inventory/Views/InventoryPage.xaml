<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Inventory.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Inventory.Views.InventoryPage"
             x:DataType="vm:InventoryViewModel"
             Title="Inventory"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource Gray100}">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="24,20">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Inventory Overview" 
                                      Description="Track stock health, reorder risk, and valuation." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="Stock Adjustment" 
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="8"
                            Padding="16,10" />
                    <Button Text="Receive Stock" 
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="16,10" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- KPI Strip and Filters -->
        <VerticalStackLayout Grid.Row="1" Padding="24,16" Spacing="16">
            <!-- Stats Strip -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                <components:MetricCardView Grid.Column="0" Title="Inventory Value" Value="{Binding TotalValuation, StringFormat='₱{0:N2}'}" Icon="💰" />
                <components:MetricCardView Grid.Column="1" Title="Low Stock Items" Value="{Binding LowStockCount, StringFormat='{0}'}" Icon="⚠️" IsPositive="False" />
                <components:MetricCardView Grid.Column="2" Title="Out of Stock" Value="{Binding OutOfStockCount, StringFormat='{0}'}" Icon="❌" IsPositive="False" />
                <components:MetricCardView Grid.Column="3" Title="Total Items" Value="{Binding Stocks.Count, StringFormat='{0}'}" Icon="📦" />
            </Grid>

            <!-- Search and Filter Bar -->
            <Border BackgroundColor="{StaticResource White}" Padding="8" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search products in inventory..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Filters" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Inventory List -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <Border Margin="24,0,24,24" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <CollectionView ItemsSource="{Binding Stocks}">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="2*,*,*,*,Auto" Padding="16" BackgroundColor="{StaticResource Gray50}">
                            <Label Grid.Column="0" Text="Product" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                            <Label Grid.Column="1" Text="Category" FontAttributes="Bold" TextColor="{StaticResource Gray600}" />
                            <Label Grid.Column="2" Text="In Stock" FontAttributes="Bold" TextColor="{StaticResource Gray600}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="3" Text="Reorder Level" FontAttributes="Bold" TextColor="{StaticResource Gray600}" HorizontalTextAlignment="End" />
                            <Label Grid.Column="4" Text="Actions" FontAttributes="Bold" TextColor="{StaticResource Gray600}" Margin="0,0,16,0" />
                        </Grid>
                    </CollectionView.Header>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductStock">
                            <Grid ColumnDefinitions="2*,*,*,*,Auto" Padding="16">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Product.Name}" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Product.Code}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                
                                <Label Grid.Column="1" Text="{Binding Product.Category.Name}" VerticalOptions="Center" TextColor="{StaticResource Gray700}" />
                                
                                <HorizontalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding BaseQuantity, StringFormat='{0:N0}'}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                                    <Label Text="{Binding Product.Unit.Abbreviation}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Grid.Column="3" Text="{Binding ReorderLevel, StringFormat='{0:N0}'}" HorizontalTextAlignment="End" VerticalOptions="Center" TextColor="{StaticResource Gray700}" />

                                <Button Grid.Column="4" 
                                        Text="Adjust" 
                                        FontSize="12"
                                        Padding="12,4"
                                        MinimumHeightRequest="32"
                                        BackgroundColor="{StaticResource Gray100}"
                                        TextColor="{StaticResource Primary}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=AdjustStockCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <components:EmptyStateView Title="No stock records found" 
                                                  Message="Try adjusting your filters or check if products have stock assigned." />
                    </CollectionView.EmptyView>
                </CollectionView>
            </Border>
        </RefreshView>
    </Grid>
</ContentPage>
