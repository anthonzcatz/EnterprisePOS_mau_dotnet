<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             xmlns:vm="clr-namespace:EnterprisePOS.Features.Inventory.ViewModels"
             xmlns:models="clr-namespace:EnterprisePOS.Core.Data.Models"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="EnterprisePOS.Features.Inventory.Views.InventoryPage"
             x:DataType="vm:InventoryViewModel"
             Title="Inventory"
             ios:Page.UseSafeArea="True"
             BackgroundColor="{StaticResource Gray100}">

    <components:AppShellLayout ActiveKey="inventory" PageTitle="Inventory">
        <components:AppShellLayout.PageBody>
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
        <!-- Header Section -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource White}" StrokeThickness="0" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}">
            <Grid ColumnDefinitions="*,Auto">
                <components:PageHeader Grid.Column="0" 
                                      Title="Inventory Overview" 
                                      Description="Track stock health, reorder risk, and valuation." />
                
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Button Text="Stock Adjustment" 
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="8"
                            Padding="16,10" />
                    <Button Text="Receive Stock" 
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="16,10" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- KPI Strip and Filters -->
        <VerticalStackLayout Grid.Row="1" Padding="{OnIdiom Phone=16, Tablet=20, Desktop=24}" Spacing="{OnIdiom Phone=12, Tablet=16, Desktop=20}">
            <!-- Stats Strip -->
            <Grid ColumnDefinitions="{OnIdiom Phone='*', Tablet='*,*', Desktop='*,*,*,*'}" ColumnSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=16}">
                <components:MetricCardView Grid.Column="0" Title="Inventory Value" Value="{Binding TotalValuation, StringFormat='₱{0:N2}'}" Icon="💰" />
                <components:MetricCardView Grid.Column="1" Title="Low Stock Items" Value="{Binding LowStockCount, StringFormat='{0}'}" Icon="⚠️" IsPositive="False" />
                <components:MetricCardView Grid.Column="2" Title="Out of Stock" Value="{Binding OutOfStockCount, StringFormat='{0}'}" Icon="❌" IsPositive="False" />
                <components:MetricCardView Grid.Column="3" Title="Total Items" Value="{Binding Stocks.Count, StringFormat='{0}'}" Icon="📦" />
            </Grid>

            <!-- Search and Filter Bar -->
            <Border BackgroundColor="{StaticResource White}" Padding="{OnIdiom Phone=6, Tablet=8, Desktop=8}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{OnIdiom Phone=8, Tablet=12, Desktop=12}">
                    <SearchBar Grid.Column="0" 
                               Placeholder="Search products in inventory..." 
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent" />
                    
                    <Button Grid.Column="1" 
                            Text="Filters" 
                            BackgroundColor="{StaticResource Gray100}"
                            TextColor="{StaticResource TextPrimary}" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Inventory List -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <Border Margin="{OnIdiom Phone=16, Tablet=20, Desktop=24}" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                <CollectionView ItemsSource="{Binding Stocks}">
                    <CollectionView.Header>
                        <Grid ColumnDefinitions="{OnIdiom Phone='*,Auto', Tablet='2*,*,*,*', Desktop='2*,*,*,*,*'}" Padding="{OnIdiom Phone=12, Tablet=16, Desktop=16}" BackgroundColor="{StaticResource Gray50}">
                            <Label Grid.Column="0" Text="Product" FontAttributes="Bold" FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}" TextColor="{StaticResource Gray600}" />
                            <Label Grid.Column="1" Text="Category" FontAttributes="Bold" FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}" TextColor="{StaticResource Gray600}" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />
                            <Label Grid.Column="2" Text="In Stock" FontAttributes="Bold" FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}" TextColor="{StaticResource Gray600}" HorizontalTextAlignment="End" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />
                            <Label Grid.Column="3" Text="Reorder Level" FontAttributes="Bold" FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}" TextColor="{StaticResource Gray600}" HorizontalTextAlignment="End" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />
                            <Label Grid.Column="4" Text="Actions" FontAttributes="Bold" FontSize="{OnIdiom Phone=12, Tablet=13, Desktop=14}" TextColor="{StaticResource Gray600}" Margin="0,0,16,0" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />
                        </Grid>
                    </CollectionView.Header>
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductStock">
                            <Grid ColumnDefinitions="{OnIdiom Phone='*,Auto', Tablet='2*,*,*,*', Desktop='2*,*,*,*,*'}" Padding="{OnIdiom Phone=12, Tablet=16, Desktop=16}">
                                <VerticalStackLayout Grid.Column="0" Spacing="{OnIdiom Phone=2, Tablet=2, Desktop=4}">
                                    <Label Text="{Binding Product.Name}" FontAttributes="Bold" FontSize="{OnIdiom Phone=13, Tablet=14, Desktop=15}" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Product.Code}" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                
                                <Label Grid.Column="1" Text="{Binding Product.Category.Name}" VerticalOptions="Center" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray700}" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />
                                
                                <HorizontalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="4" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}">
                                    <Label Text="{Binding BaseQuantity, StringFormat='{0:N0}'}" FontAttributes="Bold" FontSize="{OnIdiom Phone=14, Tablet=16, Desktop=16}" VerticalOptions="Center" />
                                    <Label Text="{Binding Product.Unit.Abbreviation}" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Grid.Column="3" Text="{Binding ReorderLevel, StringFormat='{0:N0}'}" HorizontalTextAlignment="End" VerticalOptions="Center" FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}" TextColor="{StaticResource Gray700}" IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}" />

                                <Button Grid.Column="4"
                                        Text="Adjust"
                                        FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}"
                                        Padding="{OnIdiom Phone='10,4', Tablet='12,4', Desktop='12,4'}"
                                        MinimumHeightRequest="{OnIdiom Phone=32, Tablet=32, Desktop=36}"
                                        BackgroundColor="{StaticResource Gray100}"
                                        TextColor="{StaticResource Primary}"
                                        IsVisible="{OnIdiom Phone=False, Tablet=True, Desktop=True}"
                                        Command="{Binding AdjustStockCommand}"
                                        CommandParameter="{Binding .}" />
                                <!-- Phone: Show adjust button below product info -->
                                <Button Grid.Column="1"
                                        Text="Adjust"
                                        FontSize="{OnIdiom Phone=11, Tablet=12, Desktop=13}"
                                        Padding="{OnIdiom Phone='10,4', Tablet='12,4', Desktop='12,4'}"
                                        MinimumHeightRequest="{OnIdiom Phone=32, Tablet=32, Desktop=36}"
                                        BackgroundColor="{StaticResource Gray100}"
                                        TextColor="{StaticResource Primary}"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center"
                                        IsVisible="{OnIdiom Phone=True, Tablet=False, Desktop=False}"
                                        Command="{Binding AdjustStockCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                    <CollectionView.EmptyView>
                        <components:EmptyStateView Title="No stock records found" 
                                                  Message="Try adjusting your filters or check if products have stock assigned." />
                    </CollectionView.EmptyView>
                </CollectionView>
            </Border>
        </RefreshView>
            </Grid>
        </components:AppShellLayout.PageBody>
    </components:AppShellLayout>
</ContentPage>
