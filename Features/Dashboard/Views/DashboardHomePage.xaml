<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Features.Dashboard.Views.DashboardHomePage"
             Title="Dashboard"
             BackgroundColor="{StaticResource PosCanvas}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Dashboard"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gray900}" />
            <Label Text="KPI widgets, sales charts, and realtime feed will appear here."
                   TextColor="{StaticResource PosTextMuted}"
                   FontSize="14" />
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Today's Sales" FontSize="12" TextColor="{StaticResource PosTextMuted}" />
                        <Label Text="$12,480" FontAttributes="Bold" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Orders" FontSize="12" TextColor="{StaticResource PosTextMuted}" />
                        <Label Text="186" FontAttributes="Bold" FontSize="20" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <Label Text="Inventory alerts and booking stats — coming soon."
                           TextColor="{StaticResource PosTextMuted}" />
                </Border>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
