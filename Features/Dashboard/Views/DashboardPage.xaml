<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:EnterprisePOS.Components"
             x:Class="EnterprisePOS.Features.Dashboard.Views.DashboardPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundSecondary}">

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding ShellVm.SidebarGridLength, Source={x:Reference SidebarLayout}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <components:AppShellLayout x:Name="SidebarLayout" Grid.Column="0" ActiveKey="home" />
        <ScrollView Grid.Column="1">
        <VerticalStackLayout Padding="24,20,24,28" Spacing="20">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <components:PageHeader Grid.Column="0"
                                       Eyebrow="Executive Overview"
                                       Title="Dashboard"
                                       Description="Monitor sales, operations, inventory risk, and branch activity from one responsive control center."
                                       MetaText="{Binding CurrentDate}"
                                       TitleFontSize="30" />
                <Button Grid.Column="1"
                        Text="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource DashboardPrimaryButton}"
                        VerticalOptions="Center" />
            </Grid>

            <Border BackgroundColor="{StaticResource White}"
                    Stroke="{StaticResource PosBorder}"
                    StrokeThickness="1"
                    Padding="18"
                    StrokeShape="RoundRectangle 18">
                <FlexLayout Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            AlignItems="Center">
                    <VerticalStackLayout Margin="0,0,12,10">
                        <Label Text="Active Branch"
                               FontSize="12"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="Main Branch · Morning Shift"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout Spacing="8"
                                           Margin="0,0,0,10">
                        <Border BackgroundColor="{StaticResource Gray100}"
                                Padding="10,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="Today"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray700}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource Gray100}"
                                Padding="10,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="All Terminals"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray700}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource Gray100}"
                                Padding="10,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="Realtime Sync"
                                   FontSize="12"
                                   TextColor="{StaticResource Success}" />
                        </Border>
                    </HorizontalStackLayout>
                </FlexLayout>
            </Border>

            <Label Text="KPI Snapshot"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gray900}" />

            <FlexLayout BindableLayout.ItemsSource="{Binding Metrics}"
                        Direction="Row"
                        Wrap="Wrap"
                        JustifyContent="SpaceBetween"
                        AlignItems="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <components:MetricCardView Title="{Binding Title}"
                                                   Value="{Binding Value}"
                                                   Delta="{Binding Delta}"
                                                   Icon="{Binding Icon}"
                                                   IsPositive="{Binding IsPositive}"
                                                   Command="{Binding Command}"
                                                   FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='48%', Desktop='31%'}"
                                                   Margin="0,0,0,14" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <FlexLayout Direction="Row"
                        Wrap="Wrap"
                        JustifyContent="SpaceBetween"
                        AlignItems="Start">
                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Sales Trend"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="Last 7 days performance across all transactions"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource Gray100}"
                                    Padding="10,6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="7 Days"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray700}" />
                            </Border>
                        </Grid>

                        <Border BackgroundColor="White"
                                HeightRequest="220"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Grid HeightRequest="200" ColumnDefinitions="*,*,*,*,*,*,*" RowDefinitions="Auto,*" Padding="16">
                                <!-- Y-axis labels -->
                                <VerticalStackLayout Grid.Column="0" Grid.RowSpan="2" VerticalOptions="Center" Margin="0,0,8,0">
                                    <Label Text="30k" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="End"/>
                                    <Label Text="15k" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="End"/>
                                    <Label Text="0" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="End"/>
                                </VerticalStackLayout>
                                <!-- Bars -->
                                <VerticalStackLayout Grid.Column="1" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="120" WidthRequest="20" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Mon" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="90" WidthRequest="20" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Tue" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="150" WidthRequest="20" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Wed" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="4" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="110" WidthRequest="20" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Thu" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="5" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="130" WidthRequest="20" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Fri" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="6" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="80" WidthRequest="20" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Sat" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <HorizontalStackLayout Spacing="14">
                            <HorizontalStackLayout Spacing="6">
                                <BoxView WidthRequest="10"
                                         HeightRequest="10"
                                         BackgroundColor="{StaticResource ChartBlue}"
                                         CornerRadius="5"
                                         VerticalOptions="Center" />
                                <Label Text="Sales volume"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <BoxView WidthRequest="10"
                                         HeightRequest="10"
                                         BackgroundColor="{StaticResource ChartGreen}"
                                         CornerRadius="5"
                                         VerticalOptions="Center" />
                                <Label Text="Growth trend"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Payment Mix"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="Cashless adoption and cash handling distribution"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource Gray100}"
                                    Padding="10,6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="Live"
                                       FontSize="12"
                                       TextColor="{StaticResource Success}" />
                            </Border>
                        </Grid>

                        <Border BackgroundColor="White"
                                HeightRequest="220"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Grid HeightRequest="200" Padding="16">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                                    <!-- Cash 45% -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <BoxView HeightRequest="24" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Fill"/>
                                        <Label Grid.Column="1" Text="45%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" Margin="8,0,0,0" VerticalOptions="Center"/>
                                    </Grid>
                                    <!-- Card 35% -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <BoxView HeightRequest="24" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="4" HorizontalOptions="Fill" WidthRequest="155"/>
                                        <Label Grid.Column="1" Text="35%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" Margin="8,0,0,0" VerticalOptions="Center"/>
                                    </Grid>
                                    <!-- GCash 20% -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <BoxView HeightRequest="24" BackgroundColor="{StaticResource ChartYellow}" CornerRadius="4" HorizontalOptions="Fill" WidthRequest="88"/>
                                        <Label Grid.Column="1" Text="20%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" Margin="8,0,0,0" VerticalOptions="Center"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <BoxView WidthRequest="10" HeightRequest="10" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="5" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Cash" FontSize="12" TextColor="{StaticResource Gray700}" Margin="8,0,0,0" />
                                <Label Grid.Column="2" Text="45%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <BoxView WidthRequest="10" HeightRequest="10" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="5" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Card" FontSize="12" TextColor="{StaticResource Gray700}" Margin="8,0,0,0" />
                                <Label Grid.Column="2" Text="35%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <BoxView WidthRequest="10" HeightRequest="10" BackgroundColor="{StaticResource ChartYellow}" CornerRadius="5" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="GCash" FontSize="12" TextColor="{StaticResource Gray700}" Margin="8,0,0,0" />
                                <Label Grid.Column="2" Text="20%" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </FlexLayout>

            <FlexLayout Direction="Row"
                        Wrap="Wrap"
                        JustifyContent="SpaceBetween"
                        AlignItems="Start">
                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Operational Focus"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" />

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource DangerLight}"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="!"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Danger}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Low stock review"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding LowStockCount, StringFormat='Review {0} SKUs that are close to reorder level.'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="High"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Danger}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource PosBorder}" />

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource WarningLight}"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="⏱"
                                       FontSize="14"
                                       TextColor="{StaticResource Warning}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Open transactions"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding PendingOrders, StringFormat='{0} orders are awaiting payment, kitchen completion, or release.'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="Medium"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Warning}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource PosBorder}" />

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Border BackgroundColor="{StaticResource SuccessLight}"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <Label Text="✓"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Success}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="Terminal status"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding ActiveTerminals, StringFormat='{0} terminals online with no critical outage reported.'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="Stable"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Recent Activity"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Grid.Column="1"
                                   Text="Updated live"
                                   FontSize="12"
                                   TextColor="{StaticResource Success}" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding RecentActivities}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10"
                                          Padding="0,4">
                                        <Border Grid.Column="0"
                                                WidthRequest="38"
                                                HeightRequest="38"
                                                BackgroundColor="{StaticResource Gray100}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 19">
                                            <Label Text="{Binding Initial}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Gray900}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2">
                                            <Label Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Gray900}" />
                                            <Label Text="{Binding Description}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="{Binding Time}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextMuted}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </FlexLayout>

            <FlexLayout Direction="Row"
                        Wrap="Wrap"
                        JustifyContent="SpaceBetween"
                        AlignItems="Start">
                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Sales By Branch"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" />
                        <Border BackgroundColor="White"
                                HeightRequest="200"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Grid HeightRequest="180" ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,*" Padding="16">
                                <VerticalStackLayout Grid.Column="1" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="160" WidthRequest="30" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="Main" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="120" WidthRequest="30" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="North" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Grid.Row="1" VerticalOptions="End" Spacing="4">
                                    <BoxView HeightRequest="90" WidthRequest="30" BackgroundColor="{StaticResource ChartYellow}" CornerRadius="4" HorizontalOptions="Center"/>
                                    <Label Text="South" FontSize="10" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{StaticResource White}"
                        Stroke="{StaticResource PosBorder}"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 18"
                        FlexLayout.Basis="{OnIdiom Phone='100%', Tablet='100%', Desktop='48%'}"
                        Margin="0,0,0,12">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Top Products And Categories"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" />
                        <Border BackgroundColor="White"
                                HeightRequest="160"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Grid HeightRequest="140" RowDefinitions="*,*,*">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Coffee" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="50"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="3" VerticalOptions="Center" WidthRequest="100"/>
                                    <Label Grid.Column="2" Text="120" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Burger" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="50"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="3" VerticalOptions="Center" WidthRequest="80"/>
                                    <Label Grid.Column="2" Text="95" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Fries" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="50"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartYellow}" CornerRadius="3" VerticalOptions="Center" WidthRequest="65"/>
                                    <Label Grid.Column="2" Text="80" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border BackgroundColor="White"
                                HeightRequest="160"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Grid HeightRequest="140" RowDefinitions="*,*,*">
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Beverages" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="70"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartBlue}" CornerRadius="3" VerticalOptions="Center" WidthRequest="85"/>
                                    <Label Grid.Column="2" Text="45" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Food" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="70"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartGreen}" CornerRadius="3" VerticalOptions="Center" WidthRequest="65"/>
                                    <Label Grid.Column="2" Text="65" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalOptions="Center" Padding="12">
                                    <Label Grid.Column="0" Text="Snacks" FontSize="11" TextColor="{StaticResource Gray700}" WidthRequest="70"/>
                                    <BoxView Grid.Column="1" HeightRequest="16" BackgroundColor="{StaticResource ChartYellow}" CornerRadius="3" VerticalOptions="Center" WidthRequest="45"/>
                                    <Label Grid.Column="2" Text="45" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray900}" VerticalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </FlexLayout>
        </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
