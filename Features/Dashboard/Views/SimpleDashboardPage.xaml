<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EnterprisePOS.Features.Dashboard.Views.SimpleDashboardPage"
             Title="Dashboard"
             BackgroundColor="{StaticResource BackgroundSecondary}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Header -->
            <Label Text="EnterprisePOS Dashboard"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"/>
            
            <Label Text="Welcome back! Here's your business overview."
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"/>
            
            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10"/>
            
            <!-- KPI Cards Grid -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                
                <!-- Today's Sales -->
                <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Today's Sales" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="₱12,450" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="+15% from yesterday" FontSize="12" TextColor="{StaticResource Success}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Total Orders -->
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Total Orders" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="48" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="+12% from yesterday" FontSize="12" TextColor="{StaticResource Success}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Revenue -->
                <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Revenue" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="₱15,890" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="+8% from yesterday" FontSize="12" TextColor="{StaticResource Success}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Customers -->
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Customers" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="23" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="+5% from yesterday" FontSize="12" TextColor="{StaticResource Success}"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
            
            <!-- Additional KPIs -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Low Stock" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="5" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Danger}"/>
                        <Label Text="Items need restock" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Pending Orders" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="3" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Warning}"/>
                        <Label Text="Awaiting processing" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Active Terminals" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="4" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                        <Label Text="Online now" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Frame>
                
                <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Total Products" FontSize="14" TextColor="{StaticResource TextSecondary}"/>
                        <Label Text="156" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                        <Label Text="In inventory" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
            
            <!-- Chart Placeholders -->
            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10"/>
            
            <Label Text="Sales Analytics"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"/>
            
            <!-- Sales Chart Placeholder -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True" HeightRequest="250">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Sales Trend (Last 7 Days)" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                    <BoxView HeightRequest="150" Color="{StaticResource BackgroundSecondary}" CornerRadius="8"/>
                    <Label Text="Chart will display sales data here" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Payment Methods Chart Placeholder -->
            <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True" HeightRequest="250">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Payment Methods Distribution" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                    <BoxView HeightRequest="150" Color="{StaticResource BackgroundSecondary}" CornerRadius="8"/>
                    <Label Text="Chart will display payment data here" FontSize="12" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            
            <!-- Recent Orders Section -->
            <BoxView HeightRequest="1" Color="{StaticResource BorderColor}" Margin="0,10"/>
            
            <Label Text="Recent Orders"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"/>
            
            <Frame BackgroundColor="White" CornerRadius="12" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="{StaticResource Primary}" WidthRequest="40" HeightRequest="40" CornerRadius="20" Padding="0">
                            <Label Text="JD" TextColor="White" FontAttributes="Bold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="John Doe" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="3 items · ₱450" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Frame Grid.Column="2" BackgroundColor="{StaticResource Success}" CornerRadius="12" Padding="8,4" VerticalOptions="Center">
                            <Label Text="Paid" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                        </Frame>
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{StaticResource BorderColor}"/>
                    
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="{StaticResource Warning}" WidthRequest="40" HeightRequest="40" CornerRadius="20" Padding="0">
                            <Label Text="MA" TextColor="White" FontAttributes="Bold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Maria Santos" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="5 items · ₱890" FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>
                        <Frame Grid.Column="2" BackgroundColor="{StaticResource Warning}" CornerRadius="12" Padding="8,4" VerticalOptions="Center">
                            <Label Text="Pending" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                        </Frame>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
